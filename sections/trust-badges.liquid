<section class="nm-trust-float-v2 nm-animate" aria-label="Trust indicators">
  <div class="nm-container">
    <div class="nm-trust-float-v2__card">
      {%- for block in section.blocks -%}
        <div class="nm-trust-float-v2__item" {{ block.shopify_attributes }}>
          <div class="nm-trust-float-v2__icon" aria-hidden="true">{{ block.settings.icon }}</div>
          <span style="font-size:0.75rem;font-weight:600;color:var(--nm-text);">{{ block.settings.title }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust bar",
  "tag": "section",
  "blocks": [
    {
      "type": "badge",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "✓" },
        { "type": "text", "id": "title", "label": "Label", "default": "Licensed Products" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust bar",
      "blocks": [
        { "type": "badge", "settings": { "icon": "🛡️", "title": "Licensed Products" } },
        { "type": "badge", "settings": { "icon": "🚚", "title": "Fast Worldwide Shipping" } },
        { "type": "badge", "settings": { "icon": "🔒", "title": "Secure Payments" } },
        { "type": "badge", "settings": { "icon": "👨‍⚕️", "title": "Doctor Recommended" } },
        { "type": "badge", "settings": { "icon": "✓", "title": "Verified Quality" } }
      ]
    }
  ]
}
{% endschema %}

{%- assign picked = section.settings.collection -%}
{%- if picked == blank -%}{%- assign picked = collections.all -%}{%- endif -%}

<section class="nm-catalog-desktop nm-animate">
  <div class="nm-container">
    <div class="nm-catalog-desktop__hero">
      <div class="nm-catalog-desktop__hero-bg" aria-hidden="true"></div>

      <div class="nm-catalog-desktop__hero-inner">
        <div class="nm-catalog-desktop__hero-copy">
          <h1 class="nm-catalog-desktop__title">{{ section.settings.title | default: 'Premium Wellness Catalog' }}</h1>
          <p class="nm-catalog-desktop__sub">
            {{ section.settings.subtitle | default: 'Discover scientifically formulated, pharmacist-reviewed solutions for your health journey.' }}
          </p>

          {%- if section.settings.top_pills_menu != blank -%}
            <nav class="nm-catalog-desktop__pills" aria-label="Catalog tabs">
              {%- for link in linklists[section.settings.top_pills_menu].links -%}
                <a class="nm-catalog-desktop__pill" href="{{ link.url }}">{{ link.title }}</a>
              {%- endfor -%}
            </nav>
          {%- endif -%}
        </div>

        <div class="nm-catalog-desktop__hero-media" aria-hidden="true">
          {% render 'nm-placeholder-img',
            asset: section.settings.hero_asset | default: 'placeholder-hero.svg',
            alt: 'Catalog hero',
            class: 'nm-catalog-desktop__hero-img',
            class_wrap: 'nm-catalog-desktop__hero-img-wrap',
            width: 1200,
            height: 520
          %}
        </div>
      </div>
    </div>

    <div class="nm-catalog-desktop__layout">
      <aside class="nm-catalog-desktop__sidebar" aria-label="Catalog filters">
        {%- if section.settings.sidebar_menu != blank -%}
          <div class="nm-catalog-desktop__side-block">
            <h3>Categories</h3>
            <nav class="nm-catalog-desktop__side-links" aria-label="Categories">
              {%- for link in linklists[section.settings.sidebar_menu].links -%}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {%- endfor -%}
            </nav>
          </div>
        {%- endif -%}

        {%- if section.settings.goals_menu != blank -%}
          <div class="nm-catalog-desktop__side-block">
            <h3>Health Goals</h3>
            <nav class="nm-catalog-desktop__side-links" aria-label="Health goals">
              {%- for link in linklists[section.settings.goals_menu].links -%}
                <a href="{{ link.url }}">{{ link.title }}</a>
              {%- endfor -%}
            </nav>
          </div>
        {%- endif -%}

        <div class="nm-catalog-desktop__side-block">
          <h3>Fast Shipping</h3>
          <p>Doctor Recommended</p>
        </div>
      </aside>

      <div class="nm-catalog-desktop__main">
        <div class="nm-catalog-desktop__toolbar">
          <div class="nm-catalog-desktop__toolbar-title">
            <strong>{{ section.settings.grid_title | default: 'All Products' }}</strong>
          </div>
          <div class="nm-catalog-desktop__toolbar-sort">
            <span>Sort by</span>
            <span class="nm-catalog-desktop__sort-pill">{{ section.settings.sort_label | default: 'All products' }}</span>
          </div>
        </div>

        {%- if picked != blank and picked.products_count > 0 -%}
          <div class="nm-products__grid">
            {%- for product in picked.products limit: section.settings.products_to_show -%}
              {% render 'product-card', product: product %}
            {%- endfor -%}
          </div>
        {%- else -%}
          <p class="nm-empty">Add products in Shopify Admin to show the catalog.</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Catalog page",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Premium Wellness Catalog" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" },
    { "type": "link_list", "id": "top_pills_menu", "label": "Top pills menu (tabs)" },
    { "type": "link_list", "id": "sidebar_menu", "label": "Sidebar categories menu" },
    { "type": "link_list", "id": "goals_menu", "label": "Sidebar health goals menu" },
    { "type": "collection", "id": "collection", "label": "Products source (collection)" },
    { "type": "text", "id": "grid_title", "label": "Grid title", "default": "All Products" },
    { "type": "text", "id": "sort_label", "label": "Sort label", "default": "All products" },
    { "type": "range", "id": "products_to_show", "min": 8, "max": 24, "step": 4, "default": 12, "label": "Products to show" },
    {
      "type": "select",
      "id": "hero_asset",
      "label": "Hero placeholder art",
      "default": "placeholder-hero.svg",
      "options": [
        { "value": "placeholder-hero.svg", "label": "Hero" },
        { "value": "placeholder-product-1.svg", "label": "Product 1" },
        { "value": "placeholder-product-2.svg", "label": "Product 2" },
        { "value": "placeholder-product-3.svg", "label": "Product 3" },
        { "value": "placeholder-product-4.svg", "label": "Product 4" }
      ]
    }
  ],
  "presets": [{ "name": "Catalog page" }]
}
{% endschema %}


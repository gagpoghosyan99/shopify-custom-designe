<section class="nm-hero-premium nm-animate" id="hero">
  <div class="nm-hero-premium__particles" aria-hidden="true">
    <span></span><span></span><span></span><span></span>
    <span></span><span></span><span></span><span></span>
  </div>
  <div class="nm-hero-premium__mesh" aria-hidden="true"></div>

  <div class="nm-container nm-hero-premium__grid">
    <div class="nm-hero-premium__content">
      {%- if section.settings.kicker != blank -%}
        <div class="nm-hero-premium__kicker">{{ section.settings.kicker }}</div>
      {%- endif -%}
      <h1 class="nm-hero-premium__title nm-hero-premium__title--sale">{{ section.settings.heading | default: 'BIG SALE' }}</h1>
      <p class="nm-hero-premium__text">
        {{ section.settings.text | default: 'Limited-time offers on premium wellness essentials. Shop pharmacist-reviewed formulas with fast worldwide delivery.' }}
      </p>
      {%- if section.settings.price_was != blank and section.settings.price_now != blank -%}
        <div class="nm-hero-price" aria-label="Sale price">
          <span class="nm-hero-price__badge">{{ section.settings.price_badge | default: 'Limited-time offer' }}</span>
          <span class="nm-hero-price__was">{{ section.settings.price_was }}</span>
          <span class="nm-hero-price__now">{{ section.settings.price_now }}</span>
          {%- if section.settings.price_save != blank -%}
            <span class="nm-hero-price__save">{{ section.settings.price_save }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
      {%- if section.settings.mini_description != blank -%}
        <p class="nm-hero-premium__mini">{{ section.settings.mini_description }}</p>
      {%- endif -%}
      <div class="nm-hero-premium__actions">
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="nm-btn nm-btn--lg nm-btn--cyan">
          {{ section.settings.button_label | default: 'Shop Now' }}
        </a>
        <a href="{{ section.settings.button_secondary_link | default: '/collections/best-sellers' }}" class="nm-btn nm-btn--lg nm-btn--outline-light">
          {{ section.settings.button_secondary_label | default: 'Best Sellers' }}
        </a>
        <a href="{{ section.settings.button_tertiary_link | default: '/collections/doctor-recommended' }}" class="nm-btn nm-btn--lg nm-btn--outline-light">
          {{ section.settings.button_tertiary_label | default: 'Doctor Recommended' }}
        </a>
      </div>
      <div class="nm-hero-premium__mini-trust">
        {%- for block in section.blocks -%}
          {%- if block.type == 'mini_badge' -%}
            <span {{ block.shopify_attributes }}>{{ block.settings.icon }} {{ block.settings.label }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="nm-hero-premium__visual">
      <div class="nm-hero-premium__glow-orb" aria-hidden="true"></div>
      <div class="nm-hero-premium__products">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 800 | image_tag: class: 'nm-hero-premium__product-img', loading: 'eager', alt: 'NovaMeds products' }}
        {%- else -%}
          <img
            src="{{ 'hero-sale.png' | asset_url }}"
            alt="Sale hero image"
            class="nm-hero-premium__product-img nm-hero-premium__product-img--photo"
            loading="eager"
            width="1024"
            height="576"
          >
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "blocks": [
    {
      "type": "mini_badge",
      "name": "Trust pill",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "🛡️" },
        { "type": "text", "id": "label", "label": "Label", "default": "Licensed Products" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "kicker", "label": "Small label (optional)", "default": "LIMITED TIME" },
    { "type": "image_picker", "id": "image", "label": "Hero product image (optional)" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "BIG SALE" },
    { "type": "textarea", "id": "text", "label": "Subheading", "default": "Limited-time deals on pharmacy-grade vitamins, supplements and wellness essentials. Fast delivery and secure checkout." },
    { "type": "text", "id": "price_badge", "label": "Price badge (optional)", "default": "Today only" },
    { "type": "text", "id": "price_was", "label": "Regular price (optional)", "default": "Was £59.99" },
    { "type": "text", "id": "price_now", "label": "Sale price (optional)", "default": "Now £39.99" },
    { "type": "text", "id": "price_save", "label": "Save label (optional)", "default": "Save 33%" },
    { "type": "textarea", "id": "mini_description", "label": "Mini description (optional)", "default": "Collagen Peptides — supports hair, skin, nails & joints. Unflavoured. Easy daily mix." },
    { "type": "text", "id": "button_label", "label": "Primary CTA", "default": "Shop Now" },
    { "type": "url", "id": "button_link", "label": "Primary link" },
    { "type": "text", "id": "button_secondary_label", "label": "Secondary CTA", "default": "Best Sellers" },
    { "type": "url", "id": "button_secondary_link", "label": "Secondary link" },
    { "type": "text", "id": "button_tertiary_label", "label": "Tertiary CTA", "default": "Doctor Recommended" },
    { "type": "url", "id": "button_tertiary_link", "label": "Tertiary link" }
  ],
  "presets": [
    {
      "name": "Hero banner",
      "blocks": [
        { "type": "mini_badge", "settings": { "icon": "🛡️", "label": "Licensed Products" } },
        { "type": "mini_badge", "settings": { "icon": "✓", "label": "Pharmacist Approved" } },
        { "type": "mini_badge", "settings": { "icon": "🚚", "label": "Worldwide Shipping" } }
      ]
    }
  ]
}
{% endschema %}

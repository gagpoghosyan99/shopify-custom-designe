<section class="nm-vnext-faq nm-animate" id="faq" aria-label="{{ section.settings.title | default: 'FAQ' | escape }}">
  <div class="nm-container">
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <header class="nm-vnext-section-head">
        {%- if section.settings.title != blank -%}
          <h2 class="nm-vnext-h2">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="nm-vnext-sub">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="nm-vnext-faq__list" role="list">
      {%- for block in section.blocks -%}
        <div class="nm-vnext-faq__item" data-nm-faq-item role="listitem" {{ block.shopify_attributes }}>
          <button type="button" class="nm-vnext-faq__q" data-nm-faq-question aria-expanded="false">
            {{ block.settings.question }}
          </button>
          <div class="nm-vnext-faq__a" data-nm-faq-answer>
            {{ block.settings.answer }}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Are your products pharmacist approved?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>We partner with licensed pharmacies and verify formulations with qualified pharmacists before listing products.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom FAQ",
      "blocks": [
        { "type": "question", "settings": { "question": "Are your products pharmacist approved?", "answer": "<p>We partner with licensed pharmacies and verify formulations with qualified pharmacists before listing products.</p>" } },
        { "type": "question", "settings": { "question": "How fast is shipping?", "answer": "<p>Orders placed before 2pm ship same business day. Standard delivery is 2–5 business days; express options are available at checkout.</p>" } },
        { "type": "question", "settings": { "question": "Is checkout secure?", "answer": "<p>All payments are processed through encrypted secure checkout with major cards and trusted payment methods.</p>" } }
      ]
    }
  ]
}
{% endschema %}


<section class="nm-newsletter-v2 nm-animate" id="newsletter">
  <div class="nm-container">
    <div class="nm-newsletter-v2__card">
      <h2 class="nm-newsletter-v2__title">{{ section.settings.title | default: 'Get wellness tips and exclusive offers' }}</h2>
      <p class="nm-newsletter-v2__text">{{ section.settings.text | default: 'Join NovaMeds for pharmacist-backed advice and member-only savings.' }}</p>
      {% form 'customer', class: 'nm-newsletter-v2__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="NewsletterEmail">Email</label>
        <input type="email" id="NewsletterEmail" name="contact[email]" placeholder="Enter your email" required>
        <button type="submit" class="nm-btn nm-btn--cyan">{{ section.settings.button_label | default: 'Subscribe' }}</button>
      {% endform %}
      {%- if form.posted_successfully? -%}
        <p style="margin-top:1rem;color:var(--nm-cyan-bright);font-weight:600;">Thanks for subscribing!</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Get wellness tips and exclusive offers" },
    { "type": "textarea", "id": "text", "label": "Description" },
    { "type": "text", "id": "button_label", "label": "Button", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}

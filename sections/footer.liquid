<footer class="nm-footer nm-footer--v3" role="contentinfo">
  <div class="nm-container">
    <div class="nm-footer__grid">
      <div class="nm-footer__col">
        <a href="{{ routes.root_url }}">
          <img src="{{ 'novameds-logo.png' | asset_url }}" alt="{{ settings.brand_name | default: 'NovaMeds' }}" class="nm-footer__logo-img nm-footer__logo-img--brand" loading="lazy">
        </a>
        <p class="nm-footer__tagline" style="margin-top:0.75rem;">{{ section.settings.tagline }}</p>
        <div class="nm-footer__social-v3">
          {%- if section.settings.social_facebook != blank -%}<a href="{{ section.settings.social_facebook }}" aria-label="Facebook">FB</a>{%- endif -%}
          {%- if section.settings.social_instagram != blank -%}<a href="{{ section.settings.social_instagram }}" aria-label="Instagram">IG</a>{%- endif -%}
          {%- if section.settings.social_linkedin != blank -%}<a href="{{ section.settings.social_linkedin }}" aria-label="LinkedIn">IN</a>{%- endif -%}
        </div>
      </div>

      <div class="nm-footer__col">
        <h4>Medical Trust</h4>
        <ul>
          <li><a href="/pages/certifications">Certifications</a></li>
          <li><a href="/pages/pharmacist-team">Pharmacist Team</a></li>
          <li><a href="#trusted">Quality Standards</a></li>
        </ul>
      </div>

      <div class="nm-footer__col">
        <h4>Company</h4>
        <ul>
          <li><a href="/pages/about">About Us</a></li>
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
        </ul>
      </div>

      <div class="nm-footer__col">
        <h4>Legal</h4>
        <ul>
          {%- assign nm_origin = settings.public_site_url | default: 'https://novameds.shop' | strip -%}
          {%- if nm_origin contains 'myshopify.com' -%}{%- assign nm_origin = 'https://novameds.shop' -%}{%- endif -%}
          <li><a href="{{ nm_origin }}/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="{{ nm_origin }}/policies/terms-of-service">Terms</a></li>
          <li><a href="/pages/medical-disclaimer">Medical Disclaimer</a></li>
        </ul>
      </div>
    </div>

    <div class="nm-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ settings.brand_name | default: 'NovaMeds' }}. All rights reserved.</span>
      <span style="font-size:0.75rem;opacity:0.6;">Visa · Mastercard · Amex · PayPal</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Premium wellness and healthcare solutions — science-backed, pharmacist-reviewed." },
    { "type": "url", "id": "social_facebook", "label": "Facebook" },
    { "type": "url", "id": "social_instagram", "label": "Instagram" },
    { "type": "url", "id": "social_linkedin", "label": "LinkedIn" }
  ]
}
{% endschema %}

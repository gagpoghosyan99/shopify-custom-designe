<section class="nm-section-white nm-animate" id="categories">
  <div class="nm-container">
    <h2 class="nm-section-title">{{ section.settings.title | default: 'Shop by Category' }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="nm-section-sub">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <div class="nm-cat-v3__grid">
      {%- for block in section.blocks -%}
        {%- assign link_url = block.settings.link | default: block.settings.collection.url | default: '#' -%}
        <a href="{{ link_url }}" class="nm-cat-v3__tile" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 500 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {%- elsif block.settings.collection != blank and block.settings.collection.image != blank -%}
            {{ block.settings.collection.image | image_url: width: 500 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {%- else -%}
            <div style="width:100%;height:100%;background:linear-gradient(160deg,#0e5f6e,#00c9d4);"></div>
          {%- endif -%}
          <span class="nm-cat-v3__overlay"></span>
          <span class="nm-cat-v3__shop">Shop Now →</span>
          <span class="nm-cat-v3__label">{{ block.settings.title | default: block.settings.collection.title }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category grid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Shop by Category" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Vitamins", "link": "/collections/vitamins" } },
        { "type": "category", "settings": { "title": "Men's Health", "link": "/collections/mens-health" } },
        { "type": "category", "settings": { "title": "Wellness", "link": "/collections/wellness" } },
        { "type": "category", "settings": { "title": "Energy & Performance", "link": "/collections/energy" } },
        { "type": "category", "settings": { "title": "Skincare", "link": "/collections/skincare" } },
        { "type": "category", "settings": { "title": "Accessories", "link": "/collections/accessories" } }
      ]
    }
  ]
}
{% endschema %}

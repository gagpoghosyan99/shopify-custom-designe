{%- liquid
  assign heading = section.settings.title | default: 'Vitamins & Daily Essentials'
  assign sub = section.settings.subtitle | default: 'Pharmacist-trusted formulas for energy, immunity, and everyday wellness.'
  assign limit = section.settings.products_to_show | default: 8
  assign show_arrows = section.settings.show_arrows
  assign show_compare = section.settings.show_compare_price
  assign show_ratings = section.settings.show_ratings
  assign button_text = section.settings.button_text | default: 'Shop now'
  assign filter_kw = section.settings.filter_tag | strip | downcase

  assign col = section.settings.collection
  assign handle_fallback = section.settings.collection_handle | default: 'vitamins'
  if col == blank or col.products_count == 0
    assign col = collections[handle_fallback]
  endif
  if col == blank or col.products_count == 0
    assign col = collections['best-sellers']
  endif
  if col == blank or col.products_count == 0
    assign col = collections.all
  endif

  assign view_url = section.settings.view_all_link | default: col.url
-%}

{{ 'novameds-carousel.css' | asset_url | stylesheet_tag }}
{{ 'novameds-home-vitamins.css' | asset_url | stylesheet_tag }}
<script src="{{ 'novameds-carousel.js' | asset_url }}" defer></script>

<section class="nm-vitamins nm-animate" id="home-collection-{{ section.id }}" data-nm-goals data-section-id="{{ section.id }}">
  <div class="nm-vitamins__inner">
    <header class="nm-vitamins__head">
      <div class="nm-vitamins__head-copy">
        <p class="nm-vitamins__eyebrow">{{ section.settings.eyebrow | default: 'Shop vitamins' }}</p>
        <h2 class="nm-vitamins__title">{{ heading }}</h2>
        {%- if sub != blank -%}
          <p class="nm-vitamins__sub">{{ sub }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.show_view_all and view_url != blank -%}
        <a class="nm-vitamins__view-all" href="{{ view_url }}">View all vitamins</a>
      {%- endif -%}
    </header>

    <div class="nm-goals__carousel nm-vitamins__carousel" data-nm-goals-carousel>
      {%- if show_arrows -%}
        <button class="nm-goals__arrow nm-goals__arrow--prev" type="button" data-nm-goals-prev aria-label="Scroll vitamins left">
          <span aria-hidden="true">‹</span>
        </button>
      {%- endif -%}

      <div
        class="nm-goals__track nm-goals__track--swipe"
        data-nm-goals-track
        role="region"
        aria-label="Vitamins carousel"
        tabindex="0"
      >
        {%- assign shown = 0 -%}
        {%- assign shown_ids = ',' -%}

        {%- assign featured_handles = section.settings.featured_handles | split: ',' -%}
        {%- if featured_handles.size > 0 and section.settings.featured_handles != blank -%}
          {%- for handle_item in featured_handles -%}
            {%- if shown >= limit -%}{%- break -%}{%- endif -%}
            {%- assign handle_clean = handle_item | strip -%}
            {%- if handle_clean == blank -%}{%- continue -%}{%- endif -%}
            {%- assign product = all_products[handle_clean] -%}
            {%- if product == blank -%}{%- continue -%}{%- endif -%}
            {%- assign id_token = ',' | append: product.id | append: ',' -%}
            {%- if shown_ids contains id_token -%}{%- continue -%}{%- endif -%}
            {%- render 'novameds-product-offer-card',
              product: product,
              show_compare: show_compare,
              show_ratings: show_ratings,
              button_text: button_text
            -%}
            {%- assign shown = shown | plus: 1 -%}
            {%- assign shown_ids = shown_ids | append: product.id | append: ',' -%}
          {%- endfor -%}
        {%- elsif section.settings.featured_products != blank and section.settings.featured_products.size > 0 -%}
          {%- for product in section.settings.featured_products -%}
            {%- if shown >= limit -%}{%- break -%}{%- endif -%}
            {%- if product == blank or product.id == blank -%}{%- continue -%}{%- endif -%}
            {%- assign id_token = ',' | append: product.id | append: ',' -%}
            {%- if shown_ids contains id_token -%}{%- continue -%}{%- endif -%}
            {%- render 'novameds-product-offer-card',
              product: product,
              show_compare: show_compare,
              show_ratings: show_ratings,
              button_text: button_text
            -%}
            {%- assign shown = shown | plus: 1 -%}
            {%- assign shown_ids = shown_ids | append: product.id | append: ',' -%}
          {%- endfor -%}
        {%- endif -%}

        {%- if col != blank and shown < limit -%}
          {%- for product in col.products -%}
            {%- if shown >= limit -%}{%- break -%}{%- endif -%}
            {%- assign id_token = ',' | append: product.id | append: ',' -%}
            {%- if shown_ids contains id_token -%}{%- continue -%}{%- endif -%}
            {%- render 'novameds-product-offer-card',
              product: product,
              show_compare: show_compare,
              show_ratings: show_ratings,
              button_text: button_text
            -%}
            {%- assign shown = shown | plus: 1 -%}
            {%- assign shown_ids = shown_ids | append: product.id | append: ',' -%}
          {%- endfor -%}
        {%- endif -%}

        {%- if shown < limit and collections.all != blank -%}
          {%- for product in collections.all.products -%}
            {%- if shown >= limit -%}{%- break -%}{%- endif -%}
            {%- assign id_token = ',' | append: product.id | append: ',' -%}
            {%- if shown_ids contains id_token -%}{%- continue -%}{%- endif -%}
            {%- assign include = false -%}
            {%- assign pt = product.title | downcase -%}
            {%- if filter_kw != blank -%}
              {%- if product.tags contains filter_kw or pt contains filter_kw or pt contains 'vitamin' or pt contains 'b-complex' or pt contains 'b complex' or pt contains 'multivitamin' or pt contains 'omega' or pt contains 'probiotic' or pt contains 'collagen' or pt contains 'mineral' or pt contains ' d3' or pt contains 'daily essential' -%}
                {%- assign include = true -%}
              {%- endif -%}
            {%- else -%}
              {%- assign include = true -%}
            {%- endif -%}
            {%- if include -%}
              {%- render 'novameds-product-offer-card',
                product: product,
                show_compare: show_compare,
                show_ratings: show_ratings,
                button_text: button_text
              -%}
              {%- assign shown = shown | plus: 1 -%}
              {%- assign shown_ids = shown_ids | append: product.id | append: ',' -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        {%- if shown < limit and collections.all != blank -%}
          {%- for product in collections.all.products -%}
            {%- if shown >= limit -%}{%- break -%}{%- endif -%}
            {%- assign id_token = ',' | append: product.id | append: ',' -%}
            {%- if shown_ids contains id_token -%}{%- continue -%}{%- endif -%}
            {%- render 'novameds-product-offer-card',
              product: product,
              show_compare: show_compare,
              show_ratings: show_ratings,
              button_text: button_text
            -%}
            {%- assign shown = shown | plus: 1 -%}
            {%- assign shown_ids = shown_ids | append: product.id | append: ',' -%}
          {%- endfor -%}
        {%- endif -%}

        {%- if shown == 0 and request.design_mode -%}
          <p class="nm-demo-note">Assign a vitamins collection, pick featured products, or add products tagged “vitamins”.</p>
        {%- endif -%}
      </div>

      {%- if show_arrows -%}
        <button class="nm-goals__arrow nm-goals__arrow--next" type="button" data-nm-goals-next aria-label="Scroll vitamins right">
          <span aria-hidden="true">›</span>
        </button>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home vitamins row",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop vitamins" },
    { "type": "text", "id": "title", "label": "Title", "default": "Vitamins & Daily Essentials" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Pharmacist-trusted formulas for energy, immunity, and everyday wellness." },
    { "type": "collection", "id": "collection", "label": "Vitamins collection" },
    { "type": "product_list", "id": "featured_products", "label": "Featured products (Theme Editor)", "limit": 16, "info": "Pick products in the Theme Editor. Or use comma-separated handles below." },
    { "type": "textarea", "id": "featured_handles", "label": "Featured product handles", "info": "Comma-separated handles (e.g. vitamin-d3, omega-3-fish-oil). Works in theme code and fills this row reliably." },
    { "type": "text", "id": "collection_handle", "label": "Collection handle fallback", "default": "vitamins" },
    { "type": "text", "id": "filter_tag", "label": "Filter tag/keyword", "default": "vitamins", "info": "Prefer vitamin-related products first; fills with more items if needed." },
    { "type": "range", "id": "products_to_show", "min": 4, "max": 16, "step": 2, "default": 8, "label": "Products to show" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view all link", "default": true },
    { "type": "url", "id": "view_all_link", "label": "View all link override" },
    { "type": "checkbox", "id": "show_compare_price", "label": "Show compare-at price", "default": true },
    { "type": "checkbox", "id": "show_ratings", "label": "Show ratings", "default": true },
    { "type": "checkbox", "id": "show_arrows", "label": "Show arrows", "default": true },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop now" }
  ],
  "presets": [{ "name": "Home vitamins row" }]
}
{% endschema %}

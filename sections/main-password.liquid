<div class="nm-pw">
  <img src="{{ 'novameds-logo.png' | asset_url }}" alt="{{ settings.brand_name | default: 'NovaMeds' }}" class="nm-pw__logo">

  <h1 class="nm-pw__title">Opening soon</h1>

  {%- if shop.password_message != blank -%}
    <div class="nm-pw__text">{{ shop.password_message }}</div>
  {%- else -%}
    <p class="nm-pw__text">Premium wellness &amp; healthcare solutions. We're preparing novameds.shop for launch.</p>
  {%- endif -%}

  {% form 'customer', class: 'nm-pw__form' %}
    <input type="hidden" name="contact[tags]" value="prospect, password-page">
    <label class="visually-hidden" for="PasswordEmail">Email</label>
    <input type="email" name="contact[email]" id="PasswordEmail" placeholder="Email address" required autocomplete="email">
    <button type="submit" class="nm-pw__btn">Notify me at launch</button>
  {% endform %}

  {%- if form.posted_successfully? -%}
    <p class="nm-pw__text" style="color:#0096a8;font-weight:600;">Thanks — we'll be in touch soon.</p>
  {%- endif -%}

  <div class="nm-pw__links">
    <p><button type="button" id="nm-pw-toggle" style="background:none;border:none;color:#1b4b8c;font-weight:600;font-size:0.875rem;cursor:pointer;font-family:inherit;">Enter store password</button></p>
    <div id="nm-pw-gate" hidden style="margin-top:0.75rem;">
      {% form 'storefront_password' %}
        {%- if form.errors -%}
          <p class="nm-pw__errors">Incorrect password. Try again.</p>
        {%- endif -%}
        <input type="password" name="password" placeholder="Store password" style="width:100%;padding:0.875rem 1rem;border:1px solid #e2e8f0;border-radius:12px;margin-bottom:0.5rem;font-family:inherit;font-size:1rem;">
        <button type="submit" class="nm-pw__btn" style="width:100%;">Enter NovaMeds</button>
      {% endform %}
    </div>
  </div>

  <p class="nm-pw__owner">
    Store owner? <a href="https://admin.shopify.com">Open Shopify admin</a> to preview or go live.
  </p>
</div>

<script>
  document.getElementById('nm-pw-toggle')?.addEventListener('click', function () {
    var g = document.getElementById('nm-pw-gate');
    if (g) g.hidden = !g.hidden;
  });
</script>

<style>
  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); border: 0;
  }
  .nm-pw__errors { color: #dc2626; font-size: 0.875rem; margin-bottom: 0.5rem; }
</style>

{% schema %}
{
  "name": "Password page",
  "settings": []
}
{% endschema %}

<section class="nm-section-white nm-animate" id="reviews">
  <div class="nm-container">
    <h2 class="nm-section-title">{{ section.settings.title | default: 'What Our Customers Say' }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="nm-section-sub">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <div class="nm-reviews-row">
      {%- for block in section.blocks -%}
        <article class="nm-review-card-v2" {{ block.shopify_attributes }}>
          <div class="nm-review-card-v2__head">
            <div class="nm-review-card-v2__avatar">
              {%- if block.settings.avatar != blank -%}
                {{ block.settings.avatar | image_url: width: 96 | image_tag: loading: 'lazy', alt: block.settings.author, class: 'nm-review-card-v2__photo' }}
              {%- else -%}
                {%- assign av_i = forloop.index | modulo: 3 -%}
                {%- if av_i == 0 -%}{%- assign av_i = 3 -%}{%- endif -%}
                <img src="{{ 'placeholder-avatar-' | append: av_i | append: '.svg' | asset_url }}" alt="{{ block.settings.author }}" class="nm-review-card-v2__photo" width="48" height="48" loading="lazy">
              {%- endif -%}
            </div>
            <div>
              <strong>{{ block.settings.author }}</strong>
              <div class="nm-stars" style="font-size:0.75rem;">★★★★★</div>
            </div>
          </div>
          <p style="margin:0;line-height:1.65;color:var(--nm-text);">"{{ block.settings.quote }}"</p>
          {%- if block.settings.role != blank -%}
            <p style="margin:0.5rem 0 0;font-size:0.8125rem;color:var(--nm-muted);">{{ block.settings.role }}</p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "What Our Customers Say" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "avatar", "label": "Photo" },
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Name", "default": "Sarah M." },
        { "type": "text", "id": "role", "label": "Subtitle", "default": "Verified buyer" }
      ]
    }
  ],
  "presets": [{ "name": "Testimonials" }]
}
{% endschema %}

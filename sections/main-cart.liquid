<section class="nm-cart">
  <div class="nm-container">
  {%- if cart.item_count > 0 -%}
    <form action="{{ routes.cart_url }}" method="post" id="cart-form">
      <table class="nm-cart-table">
        <thead>
          <tr>
            <th scope="col">Product</th>
            <th scope="col">Quantity</th>
            <th scope="col">Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr>
              <td>
                <a href="{{ item.url }}" style="display:flex;align-items:center;gap:1rem;color:inherit;text-decoration:none;">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 160 | image_tag: loading: 'lazy', alt: item.title }}
                  {%- endif -%}
                  <span>{{ item.product.title }}{% unless item.variant.title == 'Default Title' %} — {{ item.variant.title }}{% endunless %}</span>
                </a>
              </td>
              <td>
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity for {{ item.title }}">
              </td>
              <td>{{ item.line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      <div style="display:flex;flex-wrap:wrap;gap:1rem;margin-top:1.5rem;">
        <button type="submit" name="update" class="nm-btn nm-btn--secondary">{{ 'cart.general.update' | t }}</button>
      </div>

      <div class="nm-cart__summary">
        <h2>{{ 'cart.general.subtotal' | t }}</h2>
        <p style="font-size:1.5rem;font-weight:700;color:var(--nm-blue);margin:0 0 1rem;">{{ cart.total_price | money }}</p>
        <p style="font-size:0.875rem;color:var(--nm-muted);margin:0 0 1rem;">Taxes and shipping calculated at checkout.</p>
        <button type="submit" name="checkout" class="nm-btn nm-btn--green" style="width:100%;">
          {{ 'cart.general.checkout' | t }}
        </button>
      </div>
    </form>
  {%- else -%}
    <div class="nm-empty">
      <p>{{ 'cart.general.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="nm-btn nm-btn--primary" style="margin-top:1rem;">
        {{ 'cart.general.continue_shopping' | t }}
      </a>
    </div>
  {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": []
}
{% endschema %}

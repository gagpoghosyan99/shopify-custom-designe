{{ 'novameds-account.css' | asset_url | stylesheet_tag }}

<section class="nm-account" aria-label="Reset password">
  <div class="nm-container">
    <div class="nm-account__grid nm-account__grid--single">
      <div class="nm-account__card">
        <h2 class="nm-account__card-title">Reset your password</h2>
        <p class="nm-account__card-sub">Enter a new password for your NovaMeds account.</p>

        {% form 'reset_customer_password' %}
          {%- if form.errors -%}
            <div class="nm-account__errors">{{ form.errors | default_errors }}</div>
          {%- endif -%}

          <label class="nm-account__field">
            <span class="nm-account__label">Password</span>
            <input type="password" name="customer[password]" autocomplete="new-password" required>
          </label>

          <label class="nm-account__field">
            <span class="nm-account__label">Confirm password</span>
            <input type="password" name="customer[password_confirmation]" autocomplete="new-password" required>
          </label>

          <button type="submit" class="nm-account__submit">Reset password</button>

          <div class="nm-account__links">
            <a href="{{ routes.account_login_url }}">Back to sign in</a>
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reset password",
  "tag": "section",
  "settings": []
}
{% endschema %}

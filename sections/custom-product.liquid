{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign money_price = variant.price | money
  assign compare_at = variant.compare_at_price
  assign on_sale = false
  if compare_at > variant.price
    assign on_sale = true
  endif
-%}


<section class="nm-product-page nm-pdp" data-nm-product-page aria-label="Product">
  <div class="nm-product-shell">
    <div class="nm-product-layout" data-nm-product-layout>
      <aside class="nm-product-media" aria-label="Product media">
        <div class="nm-product-media__inner">
        <div class="nm-pdp__gallery">
          {%- if product.images.size > 0 -%}
            <div class="nm-pdp__carousel" data-nm-pdp-carousel aria-label="Swipe product images">
              {%- for image in product.images -%}
                <div class="nm-pdp__slide" data-nm-pdp-slide="{{ forloop.index0 }}">
                  {{ image | image_url: width: 1400 | image_tag: loading: 'lazy', alt: image.alt, class: 'nm-pdp__img' }}
                </div>
              {%- endfor -%}
            </div>

            <div class="nm-pdp__main" aria-label="Selected product image">
              {%- assign first_img = product.images.first -%}
              {{ first_img | image_url: width: 1400 | image_tag: loading: 'eager', alt: first_img.alt, class: 'nm-pdp__img', id: 'nm-pdp-main-img' }}
            </div>
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="nm-pdp__thumbs" aria-label="More product images">
            {%- for image in product.images -%}
              <button
                type="button"
                class="nm-pdp__thumb{% if forloop.first %} is-active{% endif %}"
                data-nm-pdp-thumb
                data-src="{{ image | image_url: width: 1400 }}"
                data-index="{{ forloop.index0 }}"
                aria-label="View image {{ forloop.index }}"
              >
                {{ image | image_url: width: 140 | image_tag: loading: 'lazy', alt: image.alt }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
        </div>
      </aside>

      <div class="nm-product-info-track">
        <div class="nm-product-info-scroll" data-nm-pdp-info-scroll>
        <div class="nm-pdp__card nm-glass">
          <div class="nm-pdp__top">
            {%- if product.vendor != blank -%}
              <div class="nm-pdp__vendor">{{ product.vendor }}</div>
            {%- endif -%}
            <h1 class="nm-pdp__title">{{ product.title }}</h1>
            <div class="nm-pdp__rating" aria-label="Reviews">
              <span class="nm-pdp__stars" aria-hidden="true">★★★★★</span>
              <span class="nm-pdp__score">{{ section.settings.rating_score | default: '4.6/5' }}</span>
              <span class="nm-pdp__reviews">{{ section.settings.rating_text | default: '(900+ Reviews)' }}</span>
              <span class="nm-pdp__rating-sep" aria-hidden="true">·</span>
              <span class="nm-pdp__trust">{{ section.settings.rating_brand | default: 'Trustpilot' }}</span>
            </div>
          </div>

          <div class="nm-pdp__price" data-nm-product-price>
            <span class="nm-pdp__now">{{ money_price }}</span>
            {%- if on_sale -%}
              <span class="nm-pdp__was">{{ compare_at | money }}</span>
              <span class="nm-pdp__save">{{ section.settings.sale_badge | default: 'Save' }}</span>
            {%- endif -%}
          </div>

          <ul class="nm-pdp__bullets" aria-label="Benefits">
            {%- assign has_benefit = false -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'benefit' -%}
                {%- assign has_benefit = true -%}
                <li {{ block.shopify_attributes }}>
                  <span aria-hidden="true">✅</span>
                  <span>{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
            {%- unless has_benefit -%}
              <li><span aria-hidden="true">✅</span><span>{{ section.settings.demo_benefit_1 | default: 'Pharmacist-reviewed, science-backed formulation' }}</span></li>
              <li><span aria-hidden="true">✅</span><span>{{ section.settings.demo_benefit_2 | default: 'Made for daily energy, immunity & wellness support' }}</span></li>
              <li><span aria-hidden="true">✅</span><span>{{ section.settings.demo_benefit_3 | default: 'Fast shipping + secure checkout' }}</span></li>
              <li><span aria-hidden="true">✅</span><span>{{ section.settings.demo_benefit_4 | default: '30-day satisfaction guarantee' }}</span></li>
            {%- endunless -%}
          </ul>

          {% form 'product', product, class: 'nm-pdp__form', id: 'nm-product-form' %}
            <input type="hidden" name="id" value="{{ variant.id }}" data-nm-variant-id>

            {%- unless product.has_only_default_variant -%}
              <div class="nm-pdp__module nm-pdp__module--variants" aria-label="Choose options">
                <div class="nm-pdp__module-head">
                  <strong>{{ section.settings.variants_title | default: 'Choose your perfect fit' }}</strong>
                </div>
                <div class="nm-pdp__options" data-nm-options>
                  {%- for opt in product.options_with_values -%}
                    {%- assign opt_name_down = opt.name | downcase -%}
                    <fieldset class="nm-pdp__opt-group" data-nm-option data-index="{{ forloop.index0 }}">
                      <legend class="nm-pdp__opt-legend">
                        {%- if opt_name_down contains 'color' -%}Choose color{%- elsif opt_name_down contains 'size' -%}Choose size{%- else -%}Choose {{ opt.name }}{%- endif -%}
                      </legend>
                      <div class="nm-pdp__opt-row" role="list">
                        {%- for val in opt.values -%}
                          {%- assign input_id = 'nm-opt-' | append: section.id | append: '-' | append: forloop.parentloop.index0 | append: '-' | append: forloop.index0 -%}
                          <label class="nm-pdp__opt" for="{{ input_id }}" role="listitem">
                            <input
                              id="{{ input_id }}"
                              class="nm-pdp__opt-input"
                              type="radio"
                              name="options[{{ opt.name | escape }}]"
                              value="{{ val | escape }}"
                              {% if opt.selected_value == val %}checked{% endif %}
                              data-nm-opt
                            >
                            <span class="nm-pdp__opt-pill">{{ val }}</span>
                          </label>
                        {%- endfor -%}
                      </div>
                    </fieldset>
                  {%- endfor -%}
                </div>
              </div>
            {%- endunless -%}

            <div class="nm-pdp__module nm-pdp__module--bundle" aria-label="Bundle and free gifts">
              <div class="nm-pdp__bundle-top">
                <span class="nm-pdp__bundle-pill">{{ section.settings.bundle_badge | default: 'SPECIAL OFFER' }}</span>
                <strong class="nm-pdp__bundle-title">{{ section.settings.bundle_title | default: 'Free bonus gifts with your order' }}</strong>
              </div>
              <div class="nm-pdp__bundle-grid" role="list">
                <div class="nm-pdp__gift" role="listitem">
                  <div class="nm-pdp__gift-img" aria-hidden="true"></div>
                  <div class="nm-pdp__gift-meta">
                    <div class="nm-pdp__gift-name">{{ section.settings.bundle_item_1 | default: 'Daily Support Guide (PDF)' }}</div>
                    <div class="nm-pdp__gift-sub">{{ section.settings.bundle_item_1_note | default: 'Included free' }}</div>
                  </div>
                </div>
                <div class="nm-pdp__gift" role="listitem">
                  <div class="nm-pdp__gift-img" aria-hidden="true"></div>
                  <div class="nm-pdp__gift-meta">
                    <div class="nm-pdp__gift-name">{{ section.settings.bundle_item_2 | default: '30‑Day Wellness Plan' }}</div>
                    <div class="nm-pdp__gift-sub">{{ section.settings.bundle_item_2_note | default: 'Included free' }}</div>
                  </div>
                </div>
                <div class="nm-pdp__gift" role="listitem">
                  <div class="nm-pdp__gift-img" aria-hidden="true"></div>
                  <div class="nm-pdp__gift-meta">
                    <div class="nm-pdp__gift-name">{{ section.settings.bundle_item_3 | default: 'Recipe + Habit Checklist' }}</div>
                    <div class="nm-pdp__gift-sub">{{ section.settings.bundle_item_3_note | default: 'Included free' }}</div>
                  </div>
                </div>
              </div>
            </div>

            <div class="nm-pdp__cta-row">
              <button type="submit" name="add" class="nm-vnext-btn nm-vnext-btn--primary nm-pdp__atc" {% unless variant.available %}disabled{% endunless %}>
                {%- if variant.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
              </button>
              <button type="button" class="nm-pdp__wish" aria-label="Save {{ product.title }}">
                ♡
              </button>
            </div>

            <div class="nm-pdp__module nm-pdp__module--bonus" aria-label="Membership and bonuses">
              <div class="nm-pdp__bonus-row">
                <div class="nm-pdp__bonus-check" aria-hidden="true">✓</div>
                <div class="nm-pdp__bonus-body">
                  <strong class="nm-pdp__bonus-title">{{ section.settings.bonus_title | default: 'Free bonus included' }}</strong>
                  <div class="nm-pdp__bonus-text">
                    {{ section.settings.bonus_text | default: 'Get a 30‑day wellness plan + habit tracker with your purchase. Cancel anytime.' }}
                  </div>
                </div>
                <div class="nm-pdp__bonus-price">
                  <span class="nm-pdp__bonus-free">{{ section.settings.bonus_free | default: 'FREE' }}</span>
                  <span class="nm-pdp__bonus-was">{{ section.settings.bonus_was | default: '$39.99' }}</span>
                </div>
              </div>
            </div>

            <p class="nm-pdp__pitch">
              {{ section.settings.pitch_text | default: 'Finally, a daily routine you can actually stick to — simple, effective support for real-world wellness.' }}
            </p>

            <div class="nm-pdp__ugc" aria-label="Videos and reviews">
              <div class="nm-pdp__ugc-row">
                <button type="button" class="nm-pdp__ugc-card" aria-label="Play video 1">
                  <span class="nm-pdp__ugc-play" aria-hidden="true">▶</span>
                  <span class="nm-pdp__ugc-caption">{{ section.settings.ugc_1 | default: 'Customer story' }}</span>
                </button>
                <button type="button" class="nm-pdp__ugc-card" aria-label="Play video 2">
                  <span class="nm-pdp__ugc-play" aria-hidden="true">▶</span>
                  <span class="nm-pdp__ugc-caption">{{ section.settings.ugc_2 | default: 'Before & after routine' }}</span>
                </button>
                <button type="button" class="nm-pdp__ugc-card" aria-label="Play video 3">
                  <span class="nm-pdp__ugc-play" aria-hidden="true">▶</span>
                  <span class="nm-pdp__ugc-caption">{{ section.settings.ugc_3 | default: 'Unboxing + review' }}</span>
                </button>
              </div>
            </div>

            <div class="nm-pdp__icons" aria-label="Key benefits">
              <div class="nm-pdp__icon">
                <span class="nm-pdp__icon-glyph" aria-hidden="true">🚚</span>
                <span class="nm-pdp__icon-text">{{ section.settings.icon_1 | default: 'Fast shipping' }}</span>
              </div>
              <div class="nm-pdp__icon">
                <span class="nm-pdp__icon-glyph" aria-hidden="true">🛡️</span>
                <span class="nm-pdp__icon-text">{{ section.settings.icon_2 | default: '30‑day guarantee' }}</span>
              </div>
              <div class="nm-pdp__icon">
                <span class="nm-pdp__icon-glyph" aria-hidden="true">⏱</span>
                <span class="nm-pdp__icon-text">{{ section.settings.icon_3 | default: 'Simple daily routine' }}</span>
              </div>
            </div>

            <div class="nm-pdp__acc" aria-label="More information">
              <div class="nm-pdp__acc-list" role="list">
                <div class="nm-pdp__acc-item" data-nm-faq-item role="listitem">
                  <button type="button" class="nm-pdp__acc-q" data-nm-faq-question aria-expanded="false">
                    {{ section.settings.acc_1_title | default: 'Why NovaMeds works' }}
                  </button>
                  <div class="nm-pdp__acc-a" data-nm-faq-answer>
                    {{ section.settings.acc_1_body | default: '<p>Built with pharmacist-first standards and transparent formulas to support consistent daily wellness habits.</p>' }}
                  </div>
                </div>
                <div class="nm-pdp__acc-item" data-nm-faq-item role="listitem">
                  <button type="button" class="nm-pdp__acc-q" data-nm-faq-question aria-expanded="false">
                    {{ section.settings.acc_2_title | default: 'What’s included' }}
                  </button>
                  <div class="nm-pdp__acc-a" data-nm-faq-answer>
                    {%- if product.description != blank -%}
                      <div class="rte nm-pdp__rte">{{ product.description }}</div>
                    {%- else -%}
                      {{ section.settings.acc_2_body | default: '<p>Your product + bonus guides + a 30‑day plan to help you stay consistent.</p>' }}
                    {%- endif -%}
                  </div>
                </div>
                <div class="nm-pdp__acc-item" data-nm-faq-item role="listitem">
                  <button type="button" class="nm-pdp__acc-q" data-nm-faq-question aria-expanded="false">
                    {{ section.settings.acc_3_title | default: '30‑Day Guarantee' }}
                  </button>
                  <div class="nm-pdp__acc-a" data-nm-faq-answer>
                    {{ section.settings.acc_3_body | default: '<p>Try it for 30 days. If you’re not satisfied, contact us and we’ll make it right.</p>' }}
                  </div>
                </div>
                <div class="nm-pdp__acc-item" data-nm-faq-item role="listitem">
                  <button type="button" class="nm-pdp__acc-q" data-nm-faq-question aria-expanded="false">
                    {{ section.settings.acc_4_title | default: 'Your wellness plan' }}
                  </button>
                  <div class="nm-pdp__acc-a" data-nm-faq-answer>
                    {{ section.settings.acc_4_body | default: '<p>We include a simple schedule and habit tracker so you can build a routine that actually fits your life.</p>' }}
                  </div>
                </div>
              </div>
            </div>

            <p class="nm-pdp__note">Secure checkout · Fast shipping · Trusted by professionals</p>
          {% endform %}
        </div>
        </div>
      </div>
    </div>
  </div>

  <div class="nm-pdp-sticky" data-nm-checkout-bar aria-label="Sticky checkout bar">
    <div class="nm-pdp-sticky__inner">
      <div class="nm-pdp-sticky__left">
        <strong class="nm-pdp-sticky__name">{{ product.title }}</strong>
        <span class="nm-pdp-sticky__price">{{ money_price }}</span>
      </div>
      <button class="nm-vnext-btn nm-vnext-btn--primary nm-pdp-sticky__btn" type="button" data-nm-scroll-to-atc>
        Add to cart
      </button>
    </div>
  </div>
</section>

<script>
  (function () {
    var thumbs = document.querySelectorAll('[data-nm-pdp-thumb]');
    var main = document.getElementById('nm-pdp-main-img');
    var carousel = document.querySelector('[data-nm-pdp-carousel]');
    var slides = document.querySelectorAll('[data-nm-pdp-slide]');

    function setActiveThumb(idx) {
      thumbs.forEach(function (t) { t.classList.remove('is-active'); });
      var match = null;
      thumbs.forEach(function (t) {
        if (String(t.getAttribute('data-index')) === String(idx)) match = t;
      });
      if (match) match.classList.add('is-active');
    }

    function scrollCarouselTo(idx) {
      if (!carousel) return;
      var slide = null;
      slides.forEach(function (s) {
        if (String(s.getAttribute('data-nm-pdp-slide')) === String(idx)) slide = s;
      });
      if (slide) {
        carousel.scrollTo({ left: slide.offsetLeft, behavior: 'smooth' });
      }
    }

    thumbs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var idx = btn.getAttribute('data-index') || '0';
        if (main) main.src = btn.getAttribute('data-src');
        setActiveThumb(idx);
        scrollCarouselTo(idx);
      });
    });

    if (carousel) {
      var ticking = false;
      carousel.addEventListener(
        'scroll',
        function () {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(function () {
            ticking = false;
            var best = 0;
            var bestDist = Infinity;
            slides.forEach(function (s) {
              var left = s.offsetLeft - carousel.scrollLeft;
              var dist = Math.abs(left);
              if (dist < bestDist) {
                bestDist = dist;
                best = parseInt(s.getAttribute('data-nm-pdp-slide') || '0', 10) || 0;
              }
            });
            setActiveThumb(best);
          });
        },
        { passive: true }
      );
    }

    var scrollBtn = document.querySelector('[data-nm-scroll-to-atc]');
    var form = document.getElementById('nm-product-form');
    if (scrollBtn && form) {
      scrollBtn.addEventListener('click', function () {
        form.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }

    // Variant + price sync for pill options
    var variants = {{ product.variants | json }};
    var optionGroups = document.querySelectorAll('[data-nm-option]');
    var idInput = document.querySelector('[data-nm-variant-id]');
    var priceWrap = document.querySelector('[data-nm-product-price]');
    var atcBtn = form ? form.querySelector('button[name="add"]') : null;

    function getSelectedOptions() {
      var selected = [];
      optionGroups.forEach(function (g) {
        var checked = g.querySelector('input[data-nm-opt]:checked');
        selected.push(checked ? checked.value : '');
      });
      return selected;
    }

    function formatMoneyFromCents(cents) {
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        var fmt = (window.NovaMeds && window.NovaMeds.moneyFormat) || (window.NovaMeds && window.NovaMeds.cfg && window.NovaMeds.cfg.moneyFormat);
        return Shopify.formatMoney(cents, fmt);
      }
      return '$' + (cents / 100).toFixed(2);
    }

    function setPrice(v) {
      if (!priceWrap || !v) return;
      var now = formatMoneyFromCents(v.price);
      var was = v.compare_at_price && v.compare_at_price > v.price ? formatMoneyFromCents(v.compare_at_price) : '';
      var html = '<span class="nm-pdp__now">' + now + '</span>';
      if (was) {
        html += '<span class="nm-pdp__was">' + was + '</span>';
        html += '<span class="nm-pdp__save">{{ section.settings.sale_badge | default: 'Save' | escape }}</span>';
      }
      priceWrap.innerHTML = html;
    }

    function onOptionsChange() {
      if (!variants || !variants.length || !idInput) return;
      var opts = getSelectedOptions();
      var match = null;
      for (var i = 0; i < variants.length; i++) {
        var v = variants[i];
        if (!v || !v.options) continue;
        var ok = true;
        for (var j = 0; j < opts.length; j++) {
          if (String(v.options[j]) !== String(opts[j])) { ok = false; break; }
        }
        if (ok) { match = v; break; }
      }
      if (!match) return;

      idInput.value = match.id;
      setPrice(match);

      if (atcBtn) {
        atcBtn.disabled = !match.available;
        atcBtn.textContent = match.available ? 'Add to cart' : 'Sold out';
      }
    }

    document.querySelectorAll('input[data-nm-opt]').forEach(function (el) {
      el.addEventListener('change', onOptionsChange);
    });

  })();
</script>

{% schema %}
{
  "name": "Custom product",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "rating_score", "label": "Rating score text", "default": "4.6/5" },
    { "type": "text", "id": "rating_text", "label": "Rating reviews text", "default": "(900+ Reviews)" },
    { "type": "text", "id": "rating_brand", "label": "Rating brand", "default": "Trustpilot" },
    { "type": "text", "id": "sale_badge", "label": "Sale badge text", "default": "Save" },

    { "type": "text", "id": "variants_title", "label": "Variants module title", "default": "Choose your perfect fit" },

    { "type": "text", "id": "bundle_badge", "label": "Bundle badge", "default": "SPECIAL OFFER" },
    { "type": "text", "id": "bundle_title", "label": "Bundle title", "default": "Free bonus gifts with your order" },
    { "type": "text", "id": "bundle_item_1", "label": "Bundle item 1", "default": "Daily Support Guide (PDF)" },
    { "type": "text", "id": "bundle_item_1_note", "label": "Bundle item 1 note", "default": "Included free" },
    { "type": "text", "id": "bundle_item_2", "label": "Bundle item 2", "default": "30‑Day Wellness Plan" },
    { "type": "text", "id": "bundle_item_2_note", "label": "Bundle item 2 note", "default": "Included free" },
    { "type": "text", "id": "bundle_item_3", "label": "Bundle item 3", "default": "Recipe + Habit Checklist" },
    { "type": "text", "id": "bundle_item_3_note", "label": "Bundle item 3 note", "default": "Included free" },

    { "type": "text", "id": "bonus_title", "label": "Bonus title", "default": "Free bonus included" },
    { "type": "textarea", "id": "bonus_text", "label": "Bonus text", "default": "Get a 30‑day wellness plan + habit tracker with your purchase. Cancel anytime." },
    { "type": "text", "id": "bonus_free", "label": "Bonus free label", "default": "FREE" },
    { "type": "text", "id": "bonus_was", "label": "Bonus compare price", "default": "$39.99" },

    { "type": "textarea", "id": "pitch_text", "label": "Persuasive paragraph", "default": "Finally, a daily routine you can actually stick to — simple, effective support for real-world wellness." },

    { "type": "text", "id": "ugc_1", "label": "UGC card 1 label", "default": "Customer story" },
    { "type": "text", "id": "ugc_2", "label": "UGC card 2 label", "default": "Before & after routine" },
    { "type": "text", "id": "ugc_3", "label": "UGC card 3 label", "default": "Unboxing + review" },

    { "type": "text", "id": "icon_1", "label": "Icon row item 1", "default": "Fast shipping" },
    { "type": "text", "id": "icon_2", "label": "Icon row item 2", "default": "30‑day guarantee" },
    { "type": "text", "id": "icon_3", "label": "Icon row item 3", "default": "Simple daily routine" },

    { "type": "text", "id": "acc_1_title", "label": "Accordion 1 title", "default": "Why NovaMeds works" },
    { "type": "richtext", "id": "acc_1_body", "label": "Accordion 1 body", "default": "<p>Built with pharmacist-first standards and transparent formulas to support consistent daily wellness habits.</p>" },
    { "type": "text", "id": "acc_2_title", "label": "Accordion 2 title", "default": "What’s included" },
    { "type": "richtext", "id": "acc_2_body", "label": "Accordion 2 body (used only if product description is empty)", "default": "<p>Your product + bonus guides + a 30‑day plan to help you stay consistent.</p>" },
    { "type": "text", "id": "acc_3_title", "label": "Accordion 3 title", "default": "30‑Day Guarantee" },
    { "type": "richtext", "id": "acc_3_body", "label": "Accordion 3 body", "default": "<p>Try it for 30 days. If you’re not satisfied, contact us and we’ll make it right.</p>" },
    { "type": "text", "id": "acc_4_title", "label": "Accordion 4 title", "default": "Your wellness plan" },
    { "type": "richtext", "id": "acc_4_body", "label": "Accordion 4 body", "default": "<p>We include a simple schedule and habit tracker so you can build a routine that actually fits your life.</p>" },

    { "type": "text", "id": "demo_benefit_1", "label": "Demo benefit 1 (when no blocks)", "default": "Pharmacist-reviewed, science-backed formulation" },
    { "type": "text", "id": "demo_benefit_2", "label": "Demo benefit 2 (when no blocks)", "default": "Made for daily energy, immunity & wellness support" },
    { "type": "text", "id": "demo_benefit_3", "label": "Demo benefit 3 (when no blocks)", "default": "Fast shipping + secure checkout" },
    { "type": "text", "id": "demo_benefit_4", "label": "Demo benefit 4 (when no blocks)", "default": "30-day satisfaction guarantee" }
  ],
  "blocks": [
    {
      "type": "benefit",

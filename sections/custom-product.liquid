{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign money_price = variant.price | money
  assign compare_at = variant.compare_at_price
  assign on_sale = false
  if compare_at > variant.price
    assign on_sale = true
  endif
-%}


<section class="nm-pdp nm-animate" aria-label="Product">
  <div class="nm-container">
    <div class="nm-pdp__grid">
      <div class="nm-pdp__media nm-glass" aria-label="Product media">
        <div class="nm-pdp__gallery">
          {%- if product.featured_image -%}
            {{ product.featured_image | image_url: width: 1400 | image_tag: loading: 'eager', alt: product.featured_image.alt, class: 'nm-pdp__img', id: 'nm-pdp-main-img' }}
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="nm-pdp__thumbs" aria-label="More product images">
            {%- for image in product.images -%}
              <button
                type="button"
                class="nm-pdp__thumb{% if forloop.first %} is-active{% endif %}"
                data-nm-pdp-thumb
                data-src="{{ image | image_url: width: 1400 }}"
                aria-label="View image {{ forloop.index }}"
              >
                {{ image | image_url: width: 140 | image_tag: loading: 'lazy', alt: image.alt }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="nm-pdp__info">
        <div class="nm-pdp__card nm-glass">
          <div class="nm-pdp__top">
            {%- if product.vendor != blank -%}
              <div class="nm-pdp__vendor">{{ product.vendor }}</div>
            {%- endif -%}
            <h1 class="nm-pdp__title">{{ product.title }}</h1>
            <div class="nm-pdp__rating" aria-label="Reviews">
              <span class="nm-pdp__stars" aria-hidden="true">★★★★★</span>
              <span class="nm-pdp__score">{{ section.settings.rating_score | default: '4.6/5' }}</span>
              <span class="nm-pdp__reviews">{{ section.settings.rating_text | default: '(900+ Reviews)' }}</span>
              <span class="nm-pdp__rating-sep" aria-hidden="true">·</span>
              <span class="nm-pdp__trust">{{ section.settings.rating_brand | default: 'Trustpilot' }}</span>
            </div>
          </div>

          <div class="nm-pdp__price" data-nm-product-price>
            <span class="nm-pdp__now">{{ money_price }}</span>
            {%- if on_sale -%}
              <span class="nm-pdp__was">{{ compare_at | money }}</span>
              <span class="nm-pdp__save">{{ section.settings.sale_badge | default: 'Save' }}</span>
            {%- endif -%}
          </div>

          {%- if section.blocks.size > 0 -%}
            <ul class="nm-pdp__bullets" aria-label="Benefits">
              {%- for block in section.blocks -%}
                {%- if block.type == 'benefit' -%}
                  <li {{ block.shopify_attributes }}>
                    <span aria-hidden="true">✅</span>
                    <span>{{ block.settings.text }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}

          {% form 'product', product, class: 'nm-pdp__form', id: 'nm-product-form' %}
            <input type="hidden" name="id" value="{{ variant.id }}" data-nm-variant-id>

            {%- unless product.has_only_default_variant -%}
              <div class="nm-pdp__options" data-nm-options>
                {%- for opt in product.options_with_values -%}
                  {%- assign opt_name_down = opt.name | downcase -%}
                  <fieldset class="nm-pdp__opt-group" data-nm-option data-index="{{ forloop.index0 }}">
                    <legend class="nm-pdp__opt-legend">
                      {%- if opt_name_down contains 'color' -%}Choose color{%- elsif opt_name_down contains 'size' -%}Choose size{%- else -%}Choose {{ opt.name }}{%- endif -%}
                    </legend>
                    <div class="nm-pdp__opt-row" role="list">
                      {%- for val in opt.values -%}
                        {%- assign input_id = 'nm-opt-' | append: section.id | append: '-' | append: forloop.parentloop.index0 | append: '-' | append: forloop.index0 -%}
                        <label class="nm-pdp__opt" for="{{ input_id }}" role="listitem">
                          <input
                            id="{{ input_id }}"
                            class="nm-pdp__opt-input"
                            type="radio"
                            name="options[{{ opt.name | escape }}]"
                            value="{{ val | escape }}"
                            {% if opt.selected_value == val %}checked{% endif %}
                            data-nm-opt
                          >
                          <span class="nm-pdp__opt-pill">{{ val }}</span>
                        </label>
                      {%- endfor -%}
                    </div>
                  </fieldset>
                {%- endfor -%}
              </div>
            {%- endunless -%}

            <div class="nm-pdp__cta-row">
              <button type="submit" name="add" class="nm-vnext-btn nm-vnext-btn--primary nm-pdp__atc" {% unless variant.available %}disabled{% endunless %}>
                {%- if variant.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
              </button>
              <button type="button" class="nm-pdp__wish" aria-label="Save {{ product.title }}">
                ♡
              </button>
            </div>

            <p class="nm-pdp__note">Secure checkout · Fast shipping · Trusted by professionals</p>
          {% endform %}
        </div>

        <div class="nm-pdp__details nm-glass">
          <h2 class="nm-pdp__h2">{{ section.settings.details_title | default: 'Details' }}</h2>
          <div class="rte nm-pdp__rte">{{ product.description }}</div>
        </div>

        {%- if section.settings.show_faq -%}
          <div class="nm-pdp__faq nm-glass" aria-label="Product FAQ">
            <h2 class="nm-pdp__h2">{{ section.settings.faq_title | default: 'FAQ' }}</h2>
            <div class="nm-vnext-faq__list" role="list">
              {%- for block in section.blocks -%}
                {%- if block.type == 'faq' -%}
                  <div class="nm-vnext-faq__item" data-nm-faq-item role="listitem" {{ block.shopify_attributes }}>
                    <button type="button" class="nm-vnext-faq__q" data-nm-faq-question aria-expanded="false">
                      {{ block.settings.question }}
                    </button>
                    <div class="nm-vnext-faq__a" data-nm-faq-answer>
                      {{ block.settings.answer }}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="nm-pdp-sticky" data-nm-checkout-bar aria-label="Sticky checkout bar">
    <div class="nm-pdp-sticky__inner">
      <div class="nm-pdp-sticky__left">
        <strong class="nm-pdp-sticky__name">{{ product.title }}</strong>
        <span class="nm-pdp-sticky__price">{{ money_price }}</span>
      </div>
      <button class="nm-vnext-btn nm-vnext-btn--primary nm-pdp-sticky__btn" type="button" data-nm-scroll-to-atc>
        Add to cart
      </button>
    </div>
  </div>
</section>

<script>
  (function () {
    var thumbs = document.querySelectorAll('[data-nm-pdp-thumb]');
    var main = document.getElementById('nm-pdp-main-img');
    thumbs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!main) return;
        main.src = btn.getAttribute('data-src');
        thumbs.forEach(function (t) { t.classList.remove('is-active'); });
        btn.classList.add('is-active');
      });
    });

    var scrollBtn = document.querySelector('[data-nm-scroll-to-atc]');
    var form = document.getElementById('nm-product-form');
    if (scrollBtn && form) {
      scrollBtn.addEventListener('click', function () {
        form.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }

    // Variant + price sync for pill options
    var variants = {{ product.variants | json }};
    var optionGroups = document.querySelectorAll('[data-nm-option]');
    var idInput = document.querySelector('[data-nm-variant-id]');
    var priceWrap = document.querySelector('[data-nm-product-price]');
    var atcBtn = form ? form.querySelector('button[name="add"]') : null;

    function getSelectedOptions() {
      var selected = [];
      optionGroups.forEach(function (g) {
        var checked = g.querySelector('input[data-nm-opt]:checked');
        selected.push(checked ? checked.value : '');
      });
      return selected;
    }

    function formatMoneyFromCents(cents) {
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        var fmt = (window.NovaMeds && window.NovaMeds.moneyFormat) || (window.NovaMeds && window.NovaMeds.cfg && window.NovaMeds.cfg.moneyFormat);
        return Shopify.formatMoney(cents, fmt);
      }
      return '$' + (cents / 100).toFixed(2);
    }

    function setPrice(v) {
      if (!priceWrap || !v) return;
      var now = formatMoneyFromCents(v.price);
      var was = v.compare_at_price && v.compare_at_price > v.price ? formatMoneyFromCents(v.compare_at_price) : '';
      var html = '<span class="nm-pdp__now">' + now + '</span>';
      if (was) {
        html += '<span class="nm-pdp__was">' + was + '</span>';
        html += '<span class="nm-pdp__save">{{ section.settings.sale_badge | default: 'Save' | escape }}</span>';
      }
      priceWrap.innerHTML = html;
    }

    function onOptionsChange() {
      if (!variants || !variants.length || !idInput) return;
      var opts = getSelectedOptions();
      var match = null;
      for (var i = 0; i < variants.length; i++) {
        var v = variants[i];
        if (!v || !v.options) continue;
        var ok = true;
        for (var j = 0; j < opts.length; j++) {
          if (String(v.options[j]) !== String(opts[j])) { ok = false; break; }
        }
        if (ok) { match = v; break; }
      }
      if (!match) return;

      idInput.value = match.id;
      setPrice(match);

      if (atcBtn) {
        atcBtn.disabled = !match.available;
        atcBtn.textContent = match.available ? 'Add to cart' : 'Sold out';
      }
    }

    document.querySelectorAll('input[data-nm-opt]').forEach(function (el) {
      el.addEventListener('change', onOptionsChange);
    });
  })();
</script>

{% schema %}
{
  "name": "Custom product",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "details_title", "label": "Details title", "default": "Details" },
    { "type": "checkbox", "id": "show_faq", "label": "Show product FAQ", "default": true },
    { "type": "text", "id": "faq_title", "label": "FAQ title", "default": "FAQ" },
    { "type": "text", "id": "rating_score", "label": "Rating score text", "default": "4.6/5" },
    { "type": "text", "id": "rating_text", "label": "Rating reviews text", "default": "(900+ Reviews)" },
    { "type": "text", "id": "rating_brand", "label": "Rating brand", "default": "Trustpilot" },
    { "type": "text", "id": "sale_badge", "label": "Sale badge text", "default": "Save" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit bullet",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Unlimited workouts & challenges" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How do I cancel?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Cancel anytime from your account portal. Contact support if you need help.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom product",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Unlimited workouts & challenges" } },
        { "type": "benefit", "settings": { "text": "Access to accountability community" } },
        { "type": "benefit", "settings": { "text": "New content added monthly" } },
        { "type": "benefit", "settings": { "text": "Meal prep guides & recipes" } },
        { "type": "faq", "settings": { "question": "How do I cancel my membership?", "answer": "<p>Cancel anytime from your subscription portal. If you need help, contact support.</p>" } }
      ]
    }
  ]
}
{% endschema %}


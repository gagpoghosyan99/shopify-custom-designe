<section class="nm-promo-eye nm-animate">
  <div class="nm-container">
    <div class="nm-promo-eye__banner">
      <div>
        {%- if section.settings.badge != blank -%}
          <span class="nm-promo-eye__badge">{{ section.settings.badge }}</span>
        {%- endif -%}
        <h2 class="nm-promo-eye__title">{{ section.settings.title | default: 'Limited Time — 15% Off Your First Order' }}</h2>
        <p class="nm-promo-eye__text">{{ section.settings.text | default: 'Start your wellness journey with pharmacist-reviewed essentials. Use code WELLNESS15 at checkout.' }}</p>
      </div>
      <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="nm-btn nm-btn--lg nm-btn--cyan" style="position:relative;z-index:1;white-space:nowrap;">
        {{ section.settings.button_label | default: 'Claim Offer' }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo banner",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "🔥 Limited offer" },
    { "type": "text", "id": "title", "label": "Title", "default": "Limited Time — 15% Off Your First Order" },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "text", "id": "button_label", "label": "Button", "default": "Claim Offer" },
    { "type": "url", "id": "button_link", "label": "Link" }
  ],
  "presets": [{ "name": "Promo banner" }]
}
{% endschema %}

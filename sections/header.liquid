<header class="nm-header">

  <div class="nm-left">

    <button class="nm-menu-btn">
      ☰
    </button>

    <span>Menu</span>

  </div>

  <a href="/" class="nm-logo">
    NOVAMEDS
  </a>

  <div class="nm-right">

    <a href="/search" class="nm-search">
      ⌕ <span>Search</span>
    </a>

    <a href="/cart" class="nm-cart">

      🛒

      <span class="nm-cart-count">
        {{ cart.item_count }}
      </span>

      <span>Cart</span>

    </a>

  </div>

</header>

<style>
.nm-header{
  width:100%;
  height:82px;
  background:#fff;
  display:grid;
  grid-template-columns:1fr auto 1fr;
  align-items:center;
  padding:0 28px;
  border-bottom:1px solid #eee;
  font-family:Arial,sans-serif;
}

.nm-left,
.nm-right{
  display:flex;
  align-items:center;
  gap:18px;
}

.nm-right{
  justify-content:flex-end;
}

.nm-menu-btn{
  background:none;
  border:none;
  font-size:34px;
  cursor:pointer;
}

.nm-logo{
  font-size:42px;
  font-weight:900;
  color:#000;
  text-decoration:none;
  letter-spacing:-2px;
}

.nm-search,
.nm-cart{
  color:#000;
  text-decoration:none;
  display:flex;
  align-items:center;
  gap:8px;
  font-size:24px;
  position:relative;
}

.nm-cart-count{
  position:absolute;
  top:-10px;
  right:38px;
  width:20px;
  height:20px;
  border-radius:50%;
  background:#111;
  color:#fff;
  font-size:12px;
  display:flex;
  align-items:center;
  justify-content:center;
}

@media(max-width:768px){

  .nm-header{
    height:68px;
    padding:0 16px;
  }

  .nm-logo{
    font-size:26px;
  }

  .nm-left span,
  .nm-right span:not(.nm-cart-count){
    display:none;
  }

  .nm-search,
  .nm-cart{
    font-size:22px;
  }

}
</style>

{% schema %}
{
  "name":"NovaMeds Header",
  "settings":[],
  "presets":[
    {
      "name":"NovaMeds Header"
    }
  ]
}
{% endschema %}
{%- liquid
  assign heading = section.settings.title | default: 'What Our Customers Say'
  assign sub = section.settings.subtitle | default: 'Real results from real people — verified buyers sharing their wellness journey.'
  assign speed = section.settings.scroll_speed | default: 45
  assign pause_hover = section.settings.pause_on_hover
-%}

{{ 'novameds-customer-reviews.css' | asset_url | stylesheet_tag }}
<script src="{{ 'novameds-customer-reviews.js' | asset_url }}" defer></script>

<section
  class="nm-creviews nm-animate{% if pause_hover %} nm-creviews--pause-hover{% endif %}"
  id="customer-reviews"
  data-nm-creviews
  data-speed="{{ speed }}"
  aria-label="{{ heading | escape }}"
  style="--nm-creviews-speed: {{ speed }}s;"
>
  <div class="nm-container">
    <header class="nm-creviews__head">
      <p class="nm-creviews__eyebrow">{{ section.settings.eyebrow | default: 'Verified customer stories' }}</p>
      <h2 class="nm-creviews__title">{{ heading }}</h2>
      {%- if sub != blank -%}
        <p class="nm-creviews__sub">{{ sub }}</p>
      {%- endif -%}
    </header>
  </div>

  <div class="nm-creviews__marquee" data-nm-creviews-marquee>
    <div class="nm-creviews__track" data-nm-creviews-track role="list">
      <div class="nm-creviews__group">
        {%- for block in section.blocks -%}
          {%- if block.type == 'story' -%}
            {%- render 'customer-review-card', block: block, card_index: forloop.index, editor_attrs: true -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="nm-creviews__group" aria-hidden="true">
        {%- for block in section.blocks -%}
          {%- if block.type == 'story' -%}
            {%- render 'customer-review-card', block: block, card_index: forloop.index, editor_attrs: false -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Verified customer stories" },
    { "type": "text", "id": "title", "label": "Title", "default": "What Our Customers Say" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Real results from real people — verified buyers sharing their wellness journey." },
    { "type": "range", "id": "scroll_speed", "label": "Scroll speed (seconds per loop)", "min": 20, "max": 80, "step": 5, "default": 45 },
    { "type": "checkbox", "id": "pause_on_hover", "label": "Pause on hover", "default": true }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Customer story",
      "settings": [
        { "type": "image_picker", "id": "before_image", "label": "Before photo" },
        { "type": "text", "id": "before_label", "label": "Before label", "default": "Before" },
        { "type": "image_picker", "id": "after_image", "label": "After photo" },
        { "type": "text", "id": "after_label", "label": "After label", "default": "After" },
        { "type": "image_picker", "id": "avatar", "label": "Customer photo" },
        { "type": "text", "id": "author", "label": "Name", "default": "Sarah M." },
        { "type": "checkbox", "id": "verified", "label": "Show verified badge", "default": true },
        { "type": "range", "id": "rating", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "goal", "label": "Goal / product", "default": "Energy & daily wellness · 6 weeks" },
        { "type": "textarea", "id": "quote", "label": "Review quote", "default": "I noticed more energy within two weeks. The quality feels premium and my routine finally sticks." },
        { "type": "text", "id": "role", "label": "Location / subtitle", "default": "Verified buyer · Austin, TX" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer reviews",
      "blocks": [
        { "type": "story", "settings": { "author": "Sarah M.", "goal": "Energy & daily wellness · 6 weeks", "quote": "I noticed more energy within two weeks. The quality feels premium and my routine finally sticks.", "role": "Verified buyer · Austin, TX", "rating": 5 } },
        { "type": "story", "settings": { "author": "James L.", "goal": "Sleep & recovery · 8 weeks", "quote": "My sleep improved and I wake up less sore after training. Exactly what my pharmacist suggested.", "role": "Verified buyer · Denver, CO", "rating": 5 } },
        { "type": "story", "settings": { "author": "Priya K.", "goal": "Skin & vitality · 10 weeks", "quote": "Visible glow and stronger nails after consistent use. Fast shipping and sealed packaging every time.", "role": "Verified buyer · Seattle, WA", "rating": 5 } },
        { "type": "story", "settings": { "author": "Marcus T.", "goal": "Joint & mobility · 12 weeks", "quote": "Less stiffness in the mornings and I move more comfortably through the day. Genuine pharmacy-grade quality.", "role": "Verified buyer · Miami, FL", "rating": 5 } }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign heading = section.settings.title | default: 'What Our Customers Say'
  assign sub = section.settings.subtitle | default: 'Real results from real people — verified buyers sharing their wellness journey.'
-%}

{{ 'novameds-customer-reviews.css' | asset_url | stylesheet_tag }}

<section class="nm-creviews nm-animate" id="customer-reviews" aria-label="{{ heading | escape }}">
  <div class="nm-container">
    <header class="nm-creviews__head">
      <p class="nm-creviews__eyebrow">{{ section.settings.eyebrow | default: 'Verified customer stories' }}</p>
      <h2 class="nm-creviews__title">{{ heading }}</h2>
      {%- if sub != blank -%}
        <p class="nm-creviews__sub">{{ sub }}</p>
      {%- endif -%}
    </header>

    <div class="nm-creviews__row" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'story' -%}
          {%- liquid
            assign stars = block.settings.rating | default: 5
            if stars > 5
              assign stars = 5
            endif
            if stars < 1
              assign stars = 1
            endif
            assign pct = stars | times: 20
          -%}
          <article class="nm-creviews__card" role="listitem" {{ block.shopify_attributes }}>
            <div class="nm-creviews__ba" aria-label="Before and after results">
              <div class="nm-creviews__ba-item nm-creviews__ba-item--before">
                {%- if block.settings.before_image != blank -%}
                  {{ block.settings.before_image
                    | image_url: width: 640
                    | image_tag:
                      widths: '320, 420, 560, 640',
                      sizes: '(min-width: 900px) 280px, 45vw',
                      loading: 'lazy',
                      decoding: 'async',
                      class: 'nm-creviews__ba-img',
                      alt: block.settings.before_label | default: 'Before'
                  }}
                {%- else -%}
                  <div class="nm-creviews__ba-ph nm-creviews__ba-ph--before" role="img" aria-label="{{ block.settings.before_label | default: 'Before' }}"></div>
                {%- endif -%}
                <span class="nm-creviews__ba-tag">{{ block.settings.before_label | default: 'Before' }}</span>
              </div>
              <div class="nm-creviews__ba-divider" aria-hidden="true">
                <span>→</span>
              </div>
              <div class="nm-creviews__ba-item nm-creviews__ba-item--after">
                {%- if block.settings.after_image != blank -%}
                  {{ block.settings.after_image
                    | image_url: width: 640
                    | image_tag:
                      widths: '320, 420, 560, 640',
                      sizes: '(min-width: 900px) 280px, 45vw',
                      loading: 'lazy',
                      decoding: 'async',
                      class: 'nm-creviews__ba-img',
                      alt: block.settings.after_label | default: 'After'
                  }}
                {%- else -%}
                  <div class="nm-creviews__ba-ph nm-creviews__ba-ph--after" role="img" aria-label="{{ block.settings.after_label | default: 'After' }}"></div>
                {%- endif -%}
                <span class="nm-creviews__ba-tag nm-creviews__ba-tag--after">{{ block.settings.after_label | default: 'After' }}</span>
              </div>
            </div>

            <div class="nm-creviews__body">
              <div class="nm-creviews__person">
                <div class="nm-creviews__avatar">
                  {%- if block.settings.avatar != blank -%}
                    {{ block.settings.avatar
                      | image_url: width: 120
                      | image_tag:
                        loading: 'lazy',
                        decoding: 'async',
                        class: 'nm-creviews__avatar-img',
                        alt: block.settings.author
                    }}
                  {%- else -%}
                    {%- assign av_i = forloop.index | modulo: 3 | plus: 1 -%}
                    <img
                      class="nm-creviews__avatar-img"
                      src="{{ 'placeholder-avatar-' | append: av_i | append: '.svg' | asset_url }}"
                      alt=""
                      width="56"
                      height="56"
                      loading="lazy"
                    >
                  {%- endif -%}
                </div>
                <div class="nm-creviews__person-meta">
                  <div class="nm-creviews__name-row">
                    <span class="nm-creviews__name">{{ block.settings.author | default: 'Verified Buyer' }}</span>
                    {%- if block.settings.verified -%}
                      <span class="nm-creviews__verified" title="Verified purchase">
                        {%- render 'icon-check-circle' -%}
                        <span>Verified</span>
                      </span>
                    {%- endif -%}
                  </div>
                  <div class="nm-creviews__rating" aria-label="Rated {{ stars }} out of 5">
                    <span class="nm-creviews__stars" aria-hidden="true">
                      <span class="nm-creviews__stars-fill" style="width: {{ pct }}%"></span>
                    </span>
                    <span class="nm-creviews__score">{{ stars }}.0</span>
                  </div>
                </div>
              </div>

              {%- if block.settings.goal != blank -%}
                <p class="nm-creviews__goal">{{ block.settings.goal }}</p>
              {%- endif -%}

              {%- if block.settings.quote != blank -%}
                <blockquote class="nm-creviews__quote">“{{ block.settings.quote }}”</blockquote>
              {%- endif -%}

              {%- if block.settings.role != blank -%}
                <p class="nm-creviews__role">{{ block.settings.role }}</p>
              {%- endif -%}
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Verified customer stories" },
    { "type": "text", "id": "title", "label": "Title", "default": "What Our Customers Say" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Real results from real people — verified buyers sharing their wellness journey." }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Customer story",
      "settings": [
        { "type": "image_picker", "id": "before_image", "label": "Before photo" },
        { "type": "text", "id": "before_label", "label": "Before label", "default": "Before" },
        { "type": "image_picker", "id": "after_image", "label": "After photo" },
        { "type": "text", "id": "after_label", "label": "After label", "default": "After" },
        { "type": "image_picker", "id": "avatar", "label": "Customer photo" },
        { "type": "text", "id": "author", "label": "Name", "default": "Sarah M." },
        { "type": "checkbox", "id": "verified", "label": "Show verified badge", "default": true },
        { "type": "range", "id": "rating", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "goal", "label": "Goal / product", "default": "Energy & daily wellness · 6 weeks" },
        { "type": "textarea", "id": "quote", "label": "Review quote", "default": "I noticed more energy within two weeks. The quality feels premium and my routine finally sticks." },
        { "type": "text", "id": "role", "label": "Location / subtitle", "default": "Verified buyer · Austin, TX" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer reviews",
      "blocks": [
        {
          "type": "story",
          "settings": {
            "author": "Sarah M.",
            "goal": "Energy & daily wellness · 6 weeks",
            "quote": "I noticed more energy within two weeks. The quality feels premium and my routine finally sticks.",
            "role": "Verified buyer · Austin, TX",
            "rating": 5
          }
        },
        {
          "type": "story",
          "settings": {
            "author": "James L.",
            "goal": "Sleep & recovery · 8 weeks",
            "quote": "My sleep improved and I wake up less sore after training. Exactly what my pharmacist suggested.",
            "role": "Verified buyer · Denver, CO",
            "rating": 5
          }
        },
        {
          "type": "story",
          "settings": {
            "author": "Priya K.",
            "goal": "Skin & vitality · 10 weeks",
            "quote": "Visible glow and stronger nails after consistent use. Fast shipping and sealed packaging every time.",
            "role": "Verified buyer · Seattle, WA",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}

{%- liquid
  assign brand = settings.brand_name | default: 'NovaMeds'
  assign heading = section.settings.heading | default: 'Contact'
  assign heading_accent = section.settings.heading_accent | default: brand
  assign sub = section.settings.subheading | default: 'Have questions about our vitamins, supplements or your order? Our team is here to help you achieve your best health.'
  assign visual = section.settings.hero_image
  if visual == blank and section.settings.use_default_visual
    assign visual_asset = 'contact-hero-visual.png'
  endif
-%}

{{ 'novameds-contact.css' | asset_url | stylesheet_tag }}

<section class="nm-contact-hero" aria-labelledby="contact-hero-title">
  <div class="nm-contact-hero__bg" aria-hidden="true">
    <span class="nm-contact-hero__glow nm-contact-hero__glow--a"></span>
    <span class="nm-contact-hero__glow nm-contact-hero__glow--b"></span>
    <span class="nm-contact-hero__pattern"></span>
  </div>

  <div class="nm-container nm-contact-hero__inner">
    <div class="nm-contact-hero__copy">
      <h1 class="nm-contact-hero__title" id="contact-hero-title">
        {{ heading }}
        <span class="nm-contact-hero__accent">{{ heading_accent }}</span>
      </h1>

      {%- if sub != blank -%}
        <p class="nm-contact-hero__sub">{{ sub }}</p>
      {%- endif -%}

      <div class="nm-contact-hero__features" aria-label="Support highlights">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' and block.settings.title != blank -%}
            <div class="nm-contact-hero__feature" {{ block.shopify_attributes }}>
              <span class="nm-contact-hero__feature-icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'support' -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 3l7 4v5c0 4.2-3 7.8-7 9-4-1.2-7-4.8-7-9V7l7-4z" stroke="currentColor" stroke-width="1.6"/><path d="M9.5 12.2l1.8 1.8 3.5-3.6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                  {%- when 'speed' -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.6"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                  {%- when 'quality' -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 3l2.4 4.8L20 9l-3.8 3.7 1 5.5L12 16.2 6.8 18.2l1-5.5L4 9l5.6-1.2L12 3z" stroke="currentColor" stroke-width="1.6"/></svg>
                  {%- else -%}
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7-4.5-7-10a4 4 0 017-2.6A4 4 0 0119 11c0 5.5-7 10-7 10z" stroke="currentColor" stroke-width="1.6"/></svg>
                {%- endcase -%}
              </span>
              <span class="nm-contact-hero__feature-text">
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.subtitle != blank -%}
                  <span>{{ block.settings.subtitle }}</span>
                {%- endif -%}
              </span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="nm-contact-hero__visual" aria-hidden="true">
      <div class="nm-contact-hero__visual-glow"></div>
      {%- if visual != blank -%}
        {{
          visual
          | image_url: width: 1200
          | image_tag:
            class: 'nm-contact-hero__img',
            widths: '600, 900, 1200',
            sizes: '(min-width: 900px) 44vw, 92vw',
            loading: 'eager',
            fetchpriority: 'high',
            alt: ''
        }}
      {%- elsif visual_asset != blank -%}
        <img class="nm-contact-hero__img" src="{{ visual_asset | asset_url }}" alt="" width="1200" height="800" loading="eager">
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact hero",
  "tag": "section",
  "class": "shopify-section--contact-hero",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent", "default": "NovaMeds" },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Have questions about our vitamins, supplements or your order? Our team is here to help you achieve your best health."
    },
    { "type": "image_picker", "id": "hero_image", "label": "Hero product image" },
    { "type": "checkbox", "id": "use_default_visual", "label": "Use bundled hero image", "default": true }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "support",
          "options": [
            { "value": "support", "label": "Shield / support" },
            { "value": "speed", "label": "Clock / speed" },
            { "value": "quality", "label": "Star / quality" },
            { "value": "heart", "label": "Heart / care" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Expert Support" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Nutrition specialists" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact hero",
      "blocks": [
        { "type": "feature", "settings": { "icon": "support", "title": "Expert Support", "subtitle": "Nutrition specialists" } },
        { "type": "feature", "settings": { "icon": "speed", "title": "Fast Response", "subtitle": "We reply quickly" } },
        { "type": "feature", "settings": { "icon": "quality", "title": "Trusted Quality", "subtitle": "Premium products" } },
        { "type": "feature", "settings": { "icon": "heart", "title": "Customer Focused", "subtitle": "Your health matters" } }
      ]
    }
  ]
}
{% endschema %}

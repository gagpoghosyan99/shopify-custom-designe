{%- assign collection = section.settings.collection -%}
{%- if collection == blank -%}
  {%- assign collection = collections['all'] -%}
{%- endif -%}

<section class="nm-section nm-best-sellers nm-animate" id="best-sellers">
  <div class="nm-container">
    <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:1rem;margin-bottom:2rem;">
      <div>
        {%- if section.settings.eyebrow != blank -%}<span class="nm-section__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2 class="nm-section__title nm-section__title--center" style="margin-bottom:0;">{{ section.settings.title | default: 'Best Sellers' }}</h2>
      </div>
      {%- if section.settings.show_view_all and collection != blank -%}
        <a href="{{ collection.url }}" class="nm-btn nm-btn--secondary">View all</a>
      {%- endif -%}
    </div>

    {%- if collection != blank and collection.products_count > 0 -%}
      <div class="nm-products__grid">
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="nm-empty">Add products to your store to display best sellers here.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Best sellers",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Best sellers" },
    { "type": "text", "id": "title", "label": "Title", "default": "Customer favorites" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 4, "max": 12, "step": 2, "default": 8, "label": "Products to show" },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view all button", "default": true }
  ],
  "presets": [{ "name": "Best sellers" }]
}
{% endschema %}

<section class="nm-section-white nm-animate" id="best-sellers">
  <div class="nm-container">
    <h2 class="nm-section-title">{{ section.settings.title | default: 'Best Sellers' }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="nm-section-sub">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- assign collection = section.settings.collection -%}
    {%- if collection == blank -%}
      {%- assign collection = collections.all -%}
    {%- endif -%}

    {%- if collection != blank and collection.products_count > 0 -%}
      <div class="nm-products__grid" style="margin-bottom:1.5rem;">
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
      {%- if section.settings.show_view_all -%}
        <p style="text-align:center;">
          <a href="{{ collection.url }}" class="nm-btn nm-btn--primary">View all products</a>
        </p>
      {%- endif -%}
    {%- else -%}
      <p class="nm-demo-note">Demo products shown — add your catalog in Shopify Admin, then pick a collection here.</p>
      <div class="nm-products__grid nm-products__grid--demo" style="margin-bottom:1.5rem;">
        {% render 'demo-product-card', index: 1, title: 'Premium Multivitamin Complex', price: '$34.99' %}
        {% render 'demo-product-card', index: 2, title: 'Omega-3 Fish Oil', price: '$28.50' %}
        {% render 'demo-product-card', index: 3, title: 'Collagen Beauty Blend', price: '$42.00' %}
        {% render 'demo-product-card', index: 4, title: "Men's Performance Stack", price: '$49.99' %}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Best sellers",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Best Sellers" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Top-rated formulas loved by our community." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 4, "max": 12, "step": 2, "default": 8, "label": "Products" },
    { "type": "checkbox", "id": "show_view_all", "label": "View all link", "default": true }
  ],
  "presets": [{ "name": "Best sellers" }]
}
{% endschema %}

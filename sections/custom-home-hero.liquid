{%- liquid
  assign primary_link = section.settings.primary_link | default: routes.all_products_collection_url
  assign secondary_link = section.settings.secondary_link | default: '/collections/best-sellers'
  assign tertiary_link = section.settings.tertiary_link | default: '/collections/all'

  assign has_photo = false
  if section.settings.hero_image != blank
    assign has_photo = true
  elsif section.settings.use_default_banner
    assign has_photo = true
  endif

  assign has_overlay = false
  if section.settings.heading != blank or section.settings.subheading != blank or section.settings.kicker != blank
    assign has_overlay = true
  endif
  if section.settings.primary_label != blank or section.settings.secondary_label != blank or section.settings.tertiary_label != blank
    assign has_overlay = true
  endif
  if section.settings.show_micro_trust
    for block in section.blocks
      if block.type == 'micro_trust' and block.settings.label != blank
        assign has_overlay = true
        break
      endif
    endfor
  endif
-%}

{% style %}
  #home-hero {
    --nm-hero-banner-max-h: {{ section.settings.banner_max_height | default: 520 }}px;
    --nm-hero-banner-ratio: {{ section.settings.banner_aspect_ratio | default: '16 / 9' }};
    --nm-hero-banner-ratio-mobile: {{ section.settings.banner_aspect_ratio_mobile | default: '16 / 10' }};
    --nm-hero-banner-focus: {{ section.settings.banner_image_focus | default: 'center center' }};
  }
{% endstyle %}

<section
  class="nm-vnext-hero nm-dark-stage nm-animate{% if has_photo %} nm-vnext-hero--photo{% endif %}{% if has_photo and has_overlay == false %} nm-vnext-hero--banner-only{% endif %}"
  id="home-hero"
  aria-label="NovaMeds hero"
>
  {%- unless has_photo -%}
    <div class="nm-vnext-hero__bg" aria-hidden="true"></div>
    <div class="nm-vnext-hero__molecules" aria-hidden="true"></div>
  {%- endunless -%}

  {%- if has_photo -%}
    <div class="nm-vnext-hero__photo" aria-hidden="true">
      {%- if section.settings.hero_image != blank -%}
        {{ section.settings.hero_image
          | image_url: width: 2600
          | image_tag:
            widths: '960, 1200, 1600, 2000, 2600',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            decoding: 'async',
            class: 'nm-vnext-hero__photo-img',
            alt: section.settings.heading | default: 'NovaMeds premium wellness'
        }}
      {%- else -%}
        <img
          class="nm-vnext-hero__photo-img"
          src="{{ 'home-hero-premium.png' | asset_url }}"
          alt="NovaMeds — Premium Wellness & Healthcare Solutions"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1024"
          height="576"
        >
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if has_overlay -%}
    <div class="nm-container nm-vnext-hero__grid">
      <div class="nm-vnext-hero__copy nm-glass">
        {%- if section.settings.kicker != blank -%}
          <div class="nm-vnext-hero__kicker">{{ section.settings.kicker }}</div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h1 class="nm-vnext-hero__title">{{ section.settings.heading }}</h1>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="nm-vnext-hero__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if section.settings.primary_label != blank or section.settings.secondary_label != blank or section.settings.tertiary_label != blank -%}
          <div class="nm-vnext-hero__actions" role="group" aria-label="Primary actions">
            {%- if section.settings.primary_label != blank -%}
              <a class="nm-vnext-btn nm-vnext-btn--primary" href="{{ primary_link }}">{{ section.settings.primary_label }}</a>
            {%- endif -%}
            {%- if section.settings.secondary_label != blank -%}
              <a class="nm-vnext-btn nm-vnext-btn--ghost" href="{{ secondary_link }}">{{ section.settings.secondary_label }}</a>
            {%- endif -%}
            {%- if section.settings.tertiary_label != blank -%}
              <a class="nm-vnext-btn nm-vnext-btn--ghost" href="{{ tertiary_link }}">{{ section.settings.tertiary_label }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.show_micro_trust -%}
          <div class="nm-vnext-hero__micro" aria-label="Trust highlights">
            {%- for block in section.blocks -%}
              {%- if block.type == 'micro_trust' and block.settings.label != blank -%}
                <span class="nm-vnext-hero__micro-item" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    <span aria-hidden="true">{{ block.settings.icon }}</span>
                  {%- endif -%}
                  <span>{{ block.settings.label }}</span>
                </span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- unless has_photo -%}
        <div class="nm-vnext-hero__visual" aria-hidden="true">
          <img class="nm-vnext-hero__img" src="{{ 'hero-sale.png' | asset_url }}" alt="" loading="eager" width="1200" height="600">
          <div class="nm-vnext-hero__glow" aria-hidden="true"></div>
        </div>
      {%- endunless -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Custom home hero",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_default_banner",
      "label": "Use premium banner image",
      "default": true,
      "info": "Shows the full-width NovaMeds hero artwork when no custom image is uploaded."
    },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Premium, pharmacist-first care" },
    { "type": "text", "id": "heading", "label": "Heading (H1)", "default": "Premium Wellness & Healthcare Solutions" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Trusted products for modern health, performance, and vitality — backed by science and pharmacist-first care." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image (optional override)" },
    {
      "type": "range",
      "id": "banner_max_height",
      "min": 280,
      "max": 900,
      "step": 10,
      "unit": "px",
      "label": "Banner max height (desktop)",
      "default": 520
    },
    {
      "type": "select",
      "id": "banner_aspect_ratio",
      "label": "Banner aspect ratio (desktop)",
      "default": "16 / 9",
      "options": [
        { "value": "21 / 9", "label": "Ultra wide (21:9)" },
        { "value": "16 / 9", "label": "Wide (16:9)" },
        { "value": "16 / 10", "label": "Medium (16:10)" },
        { "value": "4 / 3", "label": "Standard (4:3)" },
        { "value": "3 / 2", "label": "Photo (3:2)" }
      ]
    },
    {
      "type": "select",
      "id": "banner_aspect_ratio_mobile",
      "label": "Banner aspect ratio (mobile)",
      "default": "16 / 10",
      "options": [
        { "value": "16 / 9", "label": "Wide (16:9)" },
        { "value": "16 / 10", "label": "Medium (16:10)" },
        { "value": "4 / 3", "label": "Taller (4:3)" },
        { "value": "1 / 1", "label": "Square (1:1)" }
      ]
    },
    {
      "type": "select",
      "id": "banner_image_focus",
      "label": "Image focus position",
      "default": "center center",
      "options": [
        { "value": "center top", "label": "Top center" },
        { "value": "center center", "label": "Center" },
        { "value": "center bottom", "label": "Bottom center" },
        { "value": "55% 45%", "label": "Slightly right" }
      ]
    },
    { "type": "text", "id": "primary_label", "label": "Primary CTA label", "default": "Shop Now" },
    { "type": "url", "id": "primary_link", "label": "Primary CTA link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary CTA label", "default": "Best Sellers" },
    { "type": "url", "id": "secondary_link", "label": "Secondary CTA link" },
    { "type": "text", "id": "tertiary_label", "label": "Tertiary CTA label", "default": "Doctor Recommended" },
    { "type": "url", "id": "tertiary_link", "label": "Tertiary CTA link" },
    { "type": "checkbox", "id": "show_micro_trust", "label": "Show micro trust row", "default": true }
  ],
  "blocks": [
    {
      "type": "micro_trust",
      "name": "Micro trust",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "✓" },
        { "type": "text", "id": "label", "label": "Label", "default": "Pharmacist Approved" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom home hero",
      "settings": {
        "use_default_banner": true,
        "kicker": "",
        "heading": "",
        "subheading": "",
        "primary_label": "",
        "secondary_label": "",
        "tertiary_label": "",
        "show_micro_trust": false
      }
    }
  ]
}
{% endschema %}

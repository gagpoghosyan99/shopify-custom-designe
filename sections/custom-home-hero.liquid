{%- liquid
  assign heading = section.settings.heading | default: 'Premium Wellness & Healthcare Solutions'
  assign sub = section.settings.subheading | default: 'Trusted products for modern health, performance, and vitality — backed by science and pharmacist-first care.'
  assign primary_label = section.settings.primary_label | default: 'Shop Now'
  assign primary_link = section.settings.primary_link | default: routes.all_products_collection_url
  assign secondary_label = section.settings.secondary_label | default: 'Best Sellers'
  assign secondary_link = section.settings.secondary_link | default: '/collections/best-sellers'
  assign tertiary_label = section.settings.tertiary_label | default: 'Doctor Recommended'
  assign tertiary_link = section.settings.tertiary_link | default: '/collections/all'
  assign has_photo = false
  if section.settings.hero_image != blank
    assign has_photo = true
  endif
-%}

<section class="nm-vnext-hero nm-dark-stage nm-animate{% if has_photo %} nm-vnext-hero--photo{% endif %}" id="home-hero" aria-label="NovaMeds hero">
  <div class="nm-vnext-hero__bg" aria-hidden="true"></div>
  <div class="nm-vnext-hero__molecules" aria-hidden="true"></div>
  {%- if has_photo -%}
    <div class="nm-vnext-hero__photo" aria-hidden="true">
      {{ section.settings.hero_image
        | image_url: width: 2600
        | image_tag:
          widths: '960, 1200, 1600, 2000, 2600',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          decoding: 'async',
          class: 'nm-vnext-hero__photo-img',
          alt: ''
      }}
      <div class="nm-vnext-hero__photo-shade" aria-hidden="true"></div>
    </div>
  {%- endif -%}

  <div class="nm-container nm-vnext-hero__grid">
    <div class="nm-vnext-hero__copy nm-glass">
      {%- if section.settings.kicker != blank -%}
        <div class="nm-vnext-hero__kicker">{{ section.settings.kicker }}</div>
      {%- endif -%}
      <h1 class="nm-vnext-hero__title">{{ heading }}</h1>
      <p class="nm-vnext-hero__sub">{{ sub }}</p>

      <div class="nm-vnext-hero__actions" role="group" aria-label="Primary actions">
        <a class="nm-vnext-btn nm-vnext-btn--primary" href="{{ primary_link }}">{{ primary_label }}</a>
        <a class="nm-vnext-btn nm-vnext-btn--ghost" href="{{ secondary_link }}">{{ secondary_label }}</a>
        <a class="nm-vnext-btn nm-vnext-btn--ghost" href="{{ tertiary_link }}">{{ tertiary_label }}</a>
      </div>

      {%- if section.settings.show_micro_trust -%}
        <div class="nm-vnext-hero__micro" aria-label="Trust highlights">
          {%- for block in section.blocks -%}
            {%- if block.type == 'micro_trust' -%}
              <span class="nm-vnext-hero__micro-item" {{ block.shopify_attributes }}>
                <span aria-hidden="true">{{ block.settings.icon }}</span>
                <span>{{ block.settings.label }}</span>
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- unless has_photo -%}
      <div class="nm-vnext-hero__visual" aria-hidden="true">
        <img class="nm-vnext-hero__img" src="{{ 'hero-sale.png' | asset_url }}" alt="" loading="eager" width="1200" height="600">
        <div class="nm-vnext-hero__glow" aria-hidden="true"></div>
      </div>
    {%- endunless -%}
  </div>
</section>

{% schema %}
{
  "name": "Custom home hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Premium, pharmacist-first care" },
    { "type": "text", "id": "heading", "label": "Heading (H1)", "default": "Premium Wellness & Healthcare Solutions" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Trusted products for modern health, performance, and vitality — backed by science and pharmacist-first care." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "primary_label", "label": "Primary CTA label", "default": "Shop Now" },
    { "type": "url", "id": "primary_link", "label": "Primary CTA link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary CTA label", "default": "Best Sellers" },
    { "type": "url", "id": "secondary_link", "label": "Secondary CTA link" },
    { "type": "text", "id": "tertiary_label", "label": "Tertiary CTA label", "default": "Doctor Recommended" },
    { "type": "url", "id": "tertiary_link", "label": "Tertiary CTA link" },
    { "type": "checkbox", "id": "show_micro_trust", "label": "Show micro trust row", "default": true }
  ],
  "blocks": [
    {
      "type": "micro_trust",
      "name": "Micro trust",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "✓" },
        { "type": "text", "id": "label", "label": "Label", "default": "Pharmacist Approved" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom home hero",
      "blocks": [
        { "type": "micro_trust", "settings": { "icon": "🛡️", "label": "Licensed Products" } },
        { "type": "micro_trust", "settings": { "icon": "✓", "label": "Pharmacist Approved" } },
        { "type": "micro_trust", "settings": { "icon": "🚚", "label": "Worldwide Shipping" } }
      ]
    }
  ]
}
{% endschema %}


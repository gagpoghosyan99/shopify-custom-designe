<section class="nm-vnext-discount nm-animate" id="first-order" aria-label="First order discount">
  <div class="nm-container">
    <div class="nm-vnext-discount__card nm-glass nm-glow-hover">
      <div class="nm-vnext-discount__copy">
        {%- if section.settings.badge != blank -%}
          <div class="nm-vnext-discount__badge">{{ section.settings.badge }}</div>
        {%- endif -%}
        <h2 class="nm-vnext-discount__title">{{ section.settings.title | default: '15% Off Your First Order' }}</h2>
        <p class="nm-vnext-discount__text">{{ section.settings.text | default: 'Use code WELLNESS15 at checkout. Pharmacist-reviewed essentials delivered to your door.' }}</p>
      </div>
      <div class="nm-vnext-discount__cta">
        <a class="nm-vnext-btn nm-vnext-btn--primary" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
          {{ section.settings.button_label | default: 'Claim Offer' }}
        </a>
        {%- if section.settings.code != blank -%}
          <button type="button" class="nm-vnext-discount__code" data-nm-copy-code data-code="{{ section.settings.code }}" aria-label="Copy discount code">
            Code: <strong>{{ section.settings.code }}</strong>
          </button>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "First order discount",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "Limited Time Offer" },
    { "type": "text", "id": "title", "label": "Title", "default": "15% Off Your First Order" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Use code WELLNESS15 at checkout. Pharmacist-reviewed essentials delivered to your door." },
    { "type": "text", "id": "code", "label": "Discount code (optional)", "default": "WELLNESS15" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Claim Offer" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Custom first-order discount" }]
}
{% endschema %}


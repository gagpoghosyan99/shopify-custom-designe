<div class="nm-page-header nm-animate">
  <div class="nm-container">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="nm-section__subtitle" style="margin:0.5rem auto 0;max-width:36rem;">{{ collection.description }}</p>
    {%- endif -%}
  </div>
</div>

<section class="nm-section">
  <div class="nm-container">
    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="nm-collection-toolbar nm-animate">
        <p class="nm-collection-toolbar__count">{{ collection.products_count }} {{ 'collections.general.products' | t }}</p>
        <a href="{{ routes.search_url }}" class="nm-btn nm-btn--secondary nm-btn--sm" data-nm-search-open style="padding:0.5rem 1rem;font-size:0.8125rem;">Search catalog</a>
      </div>

      {%- if collection.products.size > 0 -%}
        <div class="nm-products__grid">
          {%- for product in collection.products -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="nm-pagination" style="margin-top:2rem;text-align:center;" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="nm-btn nm-btn--secondary">Previous</a>
            {%- endif -%}
            <span style="margin:0 1rem;color:var(--nm-muted);">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="nm-btn nm-btn--secondary">Next</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <p class="nm-empty">No products in this collection yet.</p>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "products_per_page", "min": 8, "max": 24, "step": 4, "default": 16, "label": "Products per page" }
  ]
}
{% endschema %}

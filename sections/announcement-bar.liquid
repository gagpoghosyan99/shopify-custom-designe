{%- if section.settings.show -%}
  <div class="nm-topbar" role="region" aria-label="Store info">
    <div class="nm-container nm-topbar__inner">
      <p>{{ section.settings.shipping_text | default: 'Free express shipping on orders over $75' }}</p>
      <div class="nm-topbar__trust">
        <span>{{ section.settings.trust_1 | default: 'Pharmacist reviewed formulas' }}</span>
        <span>|</span>
        <span>{{ section.settings.trust_2 | default: 'Secure & Trusted' }}</span>
        <span>|</span>
        <span>{{ section.settings.trust_3 | default: 'Worldwide Delivery' }}</span>
      </div>
      <div class="nm-topbar__locales" aria-hidden="true">
        <span>🇬🇧 UK</span>
        <span>🇺🇸 USA</span>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Top bar",
  "settings": [
    { "type": "checkbox", "id": "show", "label": "Show top bar", "default": true },
    { "type": "text", "id": "shipping_text", "label": "Shipping message", "default": "Free express shipping on orders over $75" },
    { "type": "text", "id": "trust_1", "label": "Trust line 1", "default": "Pharmacist reviewed formulas" },
    { "type": "text", "id": "trust_2", "label": "Trust line 2", "default": "Secure & Trusted" },
    { "type": "text", "id": "trust_3", "label": "Trust line 3", "default": "Worldwide Delivery" }
  ]
}
{% endschema %}

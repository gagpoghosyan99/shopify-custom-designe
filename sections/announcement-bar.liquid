{%- if section.settings.show and section.settings.text != blank -%}
  <div class="nm-announce" role="region" aria-label="Announcement">
    <div class="nm-container nm-announce__inner">
      <p class="nm-announce__text">{{ section.settings.text }}</p>
      {%- if section.settings.link != blank and section.settings.link_label != blank -%}
        <a href="{{ section.settings.link }}" class="nm-announce__link">{{ section.settings.link_label }} →</a>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "show", "label": "Show announcement", "default": true },
    { "type": "text", "id": "text", "label": "Text", "default": "Free express shipping on orders over $75 · Pharmacist-reviewed formulas" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop now" },
    { "type": "url", "id": "link", "label": "Link" }
  ]
}
{% endschema %}

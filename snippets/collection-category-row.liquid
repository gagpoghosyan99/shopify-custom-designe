{%- comment -%}
  @param row_id {string}
  @param title {string}
  @param row_collection {collection}
  @param source_collection {collection}
  @param fallback_tag {string}
  @param limit {number}
  @param show_view_all {boolean}
{%- endcomment -%}

{%- liquid
  assign row_limit = limit | default: 4
  assign row_title = title
  assign view_url = ''

  if row_collection != blank
    assign view_url = row_collection.url
    if row_title == blank
      assign row_title = row_collection.title
    endif
  endif

  assign has_collection_products = false
  if row_collection != blank and row_collection.products_count > 0
    assign has_collection_products = true
  endif

  assign can_use_tags = false
  if source_collection != blank and fallback_tag != blank
    assign can_use_tags = true
  endif

  assign show_row = false
  if has_collection_products or can_use_tags or request.design_mode
    assign show_row = true
  endif
-%}

{%- if show_row -%}
  <section class="nm-collection-row" aria-labelledby="nm-row-{{ row_id }}">
    <div class="nm-collection-row__head">
      <h2 class="nm-collection-row__title" id="nm-row-{{ row_id }}">{{ row_title }}</h2>
      {%- if show_view_all and view_url != blank -%}
        <a class="nm-collection-row__link" href="{{ view_url }}">View all</a>
      {%- endif -%}
    </div>

    {%- if has_collection_products -%}
      <div class="nm-products__grid nm-products__grid--row">
        {%- for product in row_collection.products limit: row_limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
    {%- elsif source_collection != blank and fallback_tag != blank -%}
      {%- assign tag_count = 0 -%}
      {%- assign fallback_slug = fallback_tag | handleize -%}
      <div class="nm-products__grid nm-products__grid--row">
        {%- for product in source_collection.products -%}
          {%- if tag_count >= row_limit -%}{%- break -%}{%- endif -%}
          {%- assign matched = false -%}
          {%- if product.tags contains fallback_tag -%}
            {%- assign matched = true -%}
          {%- else -%}
            {%- for tag in product.tags -%}
              {%- assign tag_slug = tag | handleize -%}
              {%- if tag_slug == fallback_slug -%}
                {%- assign matched = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
          {%- if matched -%}
            {% render 'product-card', product: product %}
            {%- assign tag_count = tag_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- if tag_count == 0 and request.design_mode -%}
        <p class="nm-empty nm-collection-row__empty">
          Assign a collection for “{{ row_title }}”, or tag products with <strong>{{ fallback_tag }}</strong>.
        </p>
      {%- endif -%}
    {%- elsif request.design_mode -%}
      <p class="nm-empty nm-collection-row__empty">
        Assign a collection for “{{ row_title }}” in Theme Editor.
      </p>
    {%- endif -%}
  </section>
{%- endif -%}

{%- liquid
  assign row_limit = limit | default: 4
  assign row_title = title
  assign view_url = ''
  assign coll_handle = collection_handle | default: fallback_tag | handleize
  assign resolved_collection = row_collection
  assign cards_rendered = 0

  if resolved_collection == blank or resolved_collection.products_count == 0
    if coll_handle != blank
      assign resolved_collection = collections[coll_handle]
    endif
  endif

  if resolved_collection != blank and resolved_collection.products_count > 0
    assign view_url = resolved_collection.url
    if row_title == blank
      assign row_title = resolved_collection.title
    endif
  endif

  assign keyword_list = match_keywords | split: ','
  assign fallback_slug = fallback_tag | handleize
-%}

<section class="nm-collection-row" aria-labelledby="nm-row-{{ row_id }}">
  <div class="nm-collection-row__head">
    <h2 class="nm-collection-row__title" id="nm-row-{{ row_id }}">{{ row_title }}</h2>
    {%- if show_view_all and view_url != blank -%}
      <a class="nm-collection-row__link" href="{{ view_url }}">View all</a>
    {%- endif -%}
  </div>

  <div class="nm-products__grid nm-products__grid--row">
    {%- if resolved_collection != blank and resolved_collection.products_count > 0 -%}
      {%- for product in resolved_collection.products limit: row_limit -%}
        {% render 'product-card', product: product %}
        {%- assign cards_rendered = cards_rendered | plus: 1 -%}
      {%- endfor -%}
    {%- endif -%}

    {%- if cards_rendered == 0 and source_collection != blank -%}
      {%- for product in source_collection.products -%}
        {%- if cards_rendered >= row_limit -%}{%- break -%}{%- endif -%}
        {%- assign matched = false -%}

        {%- if coll_handle != blank -%}
          {%- for coll in product.collections -%}
            {%- if coll.handle == coll_handle -%}
              {%- assign matched = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        {%- unless matched -%}
          {%- if fallback_tag != blank and product.tags contains fallback_tag -%}
            {%- assign matched = true -%}
          {%- else -%}
            {%- for tag in product.tags -%}
              {%- assign tag_slug = tag | handleize -%}
              {%- if tag_slug == fallback_slug -%}
                {%- assign matched = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endunless -%}

        {%- unless matched -%}
          {%- assign title_down = product.title | downcase -%}
          {%- for kw in keyword_list -%}
            {%- assign kw_trim = kw | strip | downcase -%}
            {%- if kw_trim != blank and title_down contains kw_trim -%}
              {%- assign matched = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endunless -%}

        {%- if matched -%}
          {% render 'product-card', product: product %}
          {%- assign cards_rendered = cards_rendered | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}

    {%- if cards_rendered == 0 and auto_split and source_collection != blank and row_index != nil -%}
      {%- assign start_at = row_index | times: row_limit -%}
      {%- assign end_at = start_at | plus: row_limit -%}
      {%- for product in source_collection.products -%}
        {%- assign idx = forloop.index0 -%}
        {%- if idx >= start_at and idx < end_at -%}
          {% render 'product-card', product: product %}
          {%- assign cards_rendered = cards_rendered | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if cards_rendered == 0 and request.design_mode -%}
    <p class="nm-empty nm-collection-row__empty">
      Add products to <strong>{{ coll_handle }}</strong>, tag them, or assign a collection in Theme Editor.
    </p>
  {%- endif -%}
</section>

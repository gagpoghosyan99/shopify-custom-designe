{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign can_quick_add = false
  if product.available and variant.available and product.has_only_default_variant
    assign can_quick_add = true
  endif
  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
    assign save_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
  endif
-%}

<article class="nm-product-card-v2 nm-animate" data-product-card>
  <div class="nm-product-card-v2__media-wrap">
    {%- if on_sale -%}
      <span class="nm-product-card-v2__badge">Save {{ save_pct }}%</span>
    {%- endif -%}
    <button type="button" class="nm-product-card-v2__wish" aria-label="Save {{ product.title }}">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 00-7.8 0L12 5.6l-1-1a5.5 5.5 0 00-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 000-7.8z"/></svg>
    </button>
    <a href="{{ product.url }}" class="nm-product-card-v2__media" tabindex="-1" aria-hidden="true">
      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.featured_image.alt | escape }}
      {%- else -%}
        <div class="nm-product-card-v2__placeholder"></div>
      {%- endif -%}
    </a>
  </div>
  <div class="nm-product-card-v2__body">
    <h3 class="nm-product-card-v2__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
    <div class="nm-product-card-v2__rating" aria-label="Rated 4.9 out of 5">
      <span class="nm-stars">★★★★★</span>
      <span>4.9</span>
    </div>
    <p class="nm-product-card-v2__price">
      {{ product.price | money }}
      {%- if on_sale -%}
        <compare-at-price>{{ product.compare_at_price | money }}</compare-at-price>
      {%- endif -%}
    </p>
    {%- if can_quick_add -%}
      <button type="button" class="nm-btn nm-btn--primary nm-btn--block" data-nm-quick-add data-variant-id="{{ variant.id }}">
        Add to Cart
      </button>
    {%- else -%}
      <a href="{{ product.url }}" class="nm-btn nm-btn--primary nm-btn--block">Add to Cart</a>
    {%- endif -%}
  </div>
</article>

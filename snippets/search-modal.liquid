<div class="nm-drawer-overlay" data-nm-search-overlay hidden></div>
<div class="nm-search-modal" data-nm-search-modal role="dialog" aria-modal="true" aria-label="Search" hidden>
  <div class="nm-search-modal__inner">
    <button type="button" class="nm-search-modal__close" data-nm-search-close aria-label="Close search">&times;</button>
    <h2 class="nm-search-modal__title">Search NovaMeds</h2>
    <form action="{{ routes.search_url }}" method="get" role="search" class="nm-search-form">
      <input
        type="search"
        name="q"
        placeholder="Vitamins, supplements, pharmacy…"
        autocomplete="off"
        aria-label="Search products"
        data-nm-search-input
      >
      <button type="submit" class="nm-btn nm-btn--primary">Search</button>
    </form>
    <p class="nm-search-modal__hint">Press <kbd>↵</kbd> to search our full catalog</p>
  </div>
</div>

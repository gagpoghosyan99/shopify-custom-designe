{%- liquid
  assign review_index = review_index | default: 1
  assign customer_slug = 'sarah'
  case review_index
    when 2
      assign customer_slug = 'james'
    when 3
      assign customer_slug = 'priya'
    when 4
      assign customer_slug = 'marcus'
    when 5
      assign customer_slug = 'sarah'
    when 6
      assign customer_slug = 'james'
  endcase

  assign avatar_file = 'review-customer-' | append: customer_slug | append: '-avatar.png'
  assign author_name = author | default: 'Verified buyer'
  assign review_quote = quote | default: 'Great quality — [product] is now part of my daily routine.'
  assign review_quote = review_quote | replace: '[product]', product.title
-%}

<article class="nm-pdp-review-card" role="listitem"{% if block_attrs %} {{ block_attrs }}{% endif %}>
  <div class="nm-pdp-review-card__head">
    <img
      class="nm-pdp-review-card__avatar"
      src="{{ avatar_file | asset_url }}"
      alt="{{ author_name | escape }}"
      width="48"
      height="48"
      loading="lazy"
      decoding="async"
    >
    <div class="nm-pdp-review-card__meta">
      <p class="nm-pdp-review-card__author">{{ author_name }}</p>
      <div class="nm-pdp-review-card__stars" aria-hidden="true">★★★★★</div>
    </div>
  </div>
  <blockquote class="nm-pdp-review-card__quote">“{{ review_quote }}”</blockquote>
</article>

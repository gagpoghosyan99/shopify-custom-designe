{%- liquid
  assign show_ratings = show_ratings | default: true
  assign style = style | default: 'offer'
  assign fallback = fallback | default: true
  assign rating_value = rating
  assign reviews_count = reviews

  if show_ratings and product != blank and rating_value == blank
    assign std_rating = product.metafields.reviews.rating.value
    if std_rating != blank
      assign rating_value = std_rating.rating
      if product.metafields.reviews.rating_count.value != blank
        assign reviews_count = product.metafields.reviews.rating_count.value
      elsif product.metafields.reviews.rating_count != blank
        assign reviews_count = product.metafields.reviews.rating_count
      endif
    endif

    if rating_value == blank
      if product.metafields.loox.avg_rating.value != blank
        assign rating_value = product.metafields.loox.avg_rating.value
      elsif product.metafields.loox.avg_rating != blank
        assign rating_value = product.metafields.loox.avg_rating
      endif
      if product.metafields.loox.num_reviews.value != blank
        assign reviews_count = product.metafields.loox.num_reviews.value
      elsif product.metafields.loox.num_reviews != blank
        assign reviews_count = product.metafields.loox.num_reviews
      endif
    endif

    if rating_value == blank and product.metafields.stamped.reviews_average != blank
      assign rating_value = product.metafields.stamped.reviews_average
      if product.metafields.stamped.reviews_count != blank
        assign reviews_count = product.metafields.stamped.reviews_count
      endif
    endif

    if rating_value == blank and product.metafields.yotpo.reviews_average != blank
      assign rating_value = product.metafields.yotpo.reviews_average
      if product.metafields.yotpo.reviews_count != blank
        assign reviews_count = product.metafields.yotpo.reviews_count
      endif
    endif

    if rating_value == blank and product.metafields.okendo.summaryData.reviewAverageValue != blank
      assign rating_value = product.metafields.okendo.summaryData.reviewAverageValue
      if product.metafields.okendo.summaryData.reviewCount != blank
        assign reviews_count = product.metafields.okendo.summaryData.reviewCount
      endif
    endif

    if rating_value == blank and product.metafields.custom.rating != blank
      assign rating_value = product.metafields.custom.rating.value | default: product.metafields.custom.rating
      if product.metafields.custom.review_count != blank
        assign reviews_count = product.metafields.custom.review_count.value | default: product.metafields.custom.review_count
      endif
    endif

    if rating_value == blank and fallback
      assign seed = product.id | modulo: 7
      assign rating_value = 4.4 | plus: seed | times: 0.1
      assign reviews_count = product.id | modulo: 900 | plus: 124
    endif
  endif
-%}

{%- if show_ratings and rating_value != blank -%}
  {%- liquid
    assign rv = rating_value | plus: 0.0
    if rv > 5
      assign rv = 5
    endif
    if rv < 0
      assign rv = 0
    endif
    assign pct = rv | times: 20
    assign rv_display = rv | round: 1
  -%}

  {%- if style == 'card' -%}
    <div class="nm-product-card-v2__rating" aria-label="Rated {{ rv_display }} out of 5{% if reviews_count != blank %} from {{ reviews_count }} reviews{% endif %}">
      <span class="nm-stars" aria-hidden="true">★★★★★</span>
      <span class="nm-product-card-v2__rating-val">{{ rv_display }}</span>
      {%- if reviews_count != blank -%}
        <span class="nm-product-card-v2__rating-count">({{ reviews_count }})</span>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="nm-offer__rating" aria-label="Rated {{ rv_display }} out of 5{% if reviews_count != blank %} from {{ reviews_count }} reviews{% endif %}">
      <span class="nm-offer__stars" aria-hidden="true">
        <span class="nm-offer__stars-fill" style="width: {{ pct }}%"></span>
      </span>
      <span class="nm-offer__rating-meta">
        <span class="nm-offer__rating-val">{{ rv_display }}</span>
        {%- if reviews_count != blank -%}
          <span class="nm-offer__rating-count">({{ reviews_count }})</span>
        {%- endif -%}
      </span>
    </div>
  {%- endif -%}
{%- endif -%}

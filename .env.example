# =============================================================================
# NovaMeds — Environment variables
# =============================================================================
# Public store:  https://novameds.shop
# Dev / CLI only: novameds.myshopify.com (never show on the customer-facing site)
# =============================================================================
# Copy to `.env` locally. NEVER commit `.env`.
# NEVER put Admin tokens or API secrets in Liquid, CSS, or JS theme files.
# =============================================================================

# REQUIRED — Shopify CLI only (theme dev / push)
# Admin → Settings → Domains → *.myshopify.com (internal, not public)
SHOPIFY_STORE_DOMAIN=novameds.myshopify.com

# OPTIONAL — Theme Access password (enables CLI without browser login)
# Admin → Apps → Theme Access → Create theme password → paste here (starts with shptka_)
# SHOPIFY_CLI_THEME_TOKEN=shptka_your_theme_access_password

# REQUIRED — Public canonical URL for scripts, SEO tooling, redirects
# Admin → Settings → Domains → set novameds.shop as primary domain
PUBLIC_SITE_URL=https://novameds.shop

# OPTIONAL — Theme upload needs no tokens below
# ─────────────────────────────────────────
# shopify theme dev --store novameds.myshopify.com
# shopify theme push --store novameds.myshopify.com

# OPTIONAL — Storefront API (server-side / headless scripts only)
# Admin → Settings → Apps and sales channels → Develop apps → Create app
# → Storefront API scopes: products, collections, cart (as needed)
# → Install → API credentials → Storefront API access token
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# OPTIONAL — Admin API (private backend scripts only)
# Same app → Admin API scopes: products, orders, customers (minimum needed)
SHOPIFY_ADMIN_API_ACCESS_TOKEN=

# OPTIONAL — Custom app OAuth
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# OPTIONAL — API version for REST/GraphQL scripts
# https://shopify.dev/docs/api/usage/versioning
SHOPIFY_API_VERSION=2025-04

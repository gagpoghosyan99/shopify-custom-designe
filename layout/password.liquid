<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ shop.name }} — Opening soon</title>
    <meta name="robots" content="noindex, nofollow">
    {{ content_for_header }}
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      :root {
        --nm-blue: #1b4b8c;
        --nm-teal: #00b4c8;
        --nm-text: #0f172a;
        --nm-muted: #64748b;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: "DM Sans", system-ui, sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.25rem;
        background: linear-gradient(160deg, #e8f2fc 0%, #fff 40%, #e0f7fa 100%);
        color: var(--nm-text);
      }
      .nm-pw { width: min(100%, 440px); text-align: center; }
      .nm-pw__logo { height: 56px; width: auto; margin: 0 auto 1.5rem; display: block; }
      .nm-pw__title { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.5rem; letter-spacing: -0.02em; }
      .nm-pw__text { color: var(--nm-muted); margin-bottom: 1.5rem; line-height: 1.6; font-size: 1rem; }
      .nm-pw__form { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }
      .nm-pw__form input[type="email"] {
        padding: 0.875rem 1rem;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-size: 1rem;
        font-family: inherit;
      }
      .nm-pw__form input[type="email"]:focus {
        outline: none;
        border-color: var(--nm-teal);
      }
      .nm-pw__btn {
        padding: 0.875rem 1.25rem;
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        background: linear-gradient(135deg, var(--nm-blue), var(--nm-teal));
        color: #fff;
      }
      .nm-pw__links { font-size: 0.875rem; }
      .nm-pw__links a { color: var(--nm-blue); font-weight: 600; text-decoration: none; }
      .nm-pw__links a:hover { color: var(--nm-teal); }
      .nm-pw__links p { margin: 0.5rem 0; color: var(--nm-muted); }
      .nm-pw__owner { margin-top: 1.25rem; font-size: 0.8125rem; color: var(--nm-muted); }
      .nm-pw__errors { color: #dc2626; font-size: 0.875rem; margin-bottom: 0.75rem; }
    </style>
  </head>
  <body>
    {{ content_for_layout }}
  </body>
</html>
